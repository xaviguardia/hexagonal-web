        code: [
          cm('// Circuit Breaker: decorador que protege llamadas a servicios externos'),
          `${kw('type')} ${tp('State')} = ${st('"CLOSED"')} | ${st('"OPEN"')} | ${st('"HALF_OPEN"')};`,
          '',
          `${kw('export class')} ${tp('CircuitBreaker')}&lt;T&gt; {`,
          `  ${kw('private')} state${op(':')}      ${tp('State')} = ${st('"CLOSED"')};`,
          `  ${kw('private')} failures  = ${nm('0')};`,
          `  ${kw('private')} lastFail  = ${nm('0')};`,
          '',
