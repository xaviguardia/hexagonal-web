        concept: { label: 'Capa de Dominio', href: '#dominio' },
        code: [
          cm('// Entidad raíz del agregado. Sin imports externos.'),
          `${kw('import')} { ${tp('DomainEvent')} } ${kw('from')} ${st("'../events/DomainEvent'")};`,
          `${kw('import')} { ${tp('OrderId')} }    ${kw('from')} ${st("'../value-objects/OrderId'")};`,
          '',
          `${kw('export class')} ${tp('Order')} {`,
          `  ${kw('private')} _events${op(':')} ${tp('DomainEvent')}[] = [];`,
          '',
          `  ${kw('private')} ${fn('constructor')}(`,
          `    ${kw('public readonly')} id${op(':')}         ${tp('OrderId')},`,
          `    ${kw('public readonly')} customerId${op(':')} ${tp('string')},`,
          `    ${kw('public')} status${op(':')}              ${tp('OrderStatus')},`,
          `    ${kw('public readonly')} items${op(':')}      ${tp('OrderItem')}[],`,
          `  ) {}`,
          '',
          `  ${kw('static')} ${fn('create')}(id${op(':')} ${tp('OrderId')}, customerId${op(':')} ${tp('string')}, items${op(':')} ${tp('OrderItem')}[])${op(':')} ${tp('Order')} {`,
          `    ${kw('if')} (!items.length) ${kw('throw new')} ${fn('DomainError')}(${st('"Order needs at least one item"')});`,
          `    ${kw('const')} order = ${kw('new')} ${tp('Order')}(id, customerId, ${st('"PENDING"')}, items);`,
          `    order.${fn('record')}(${kw('new')} ${tp('OrderCreatedEvent')}(id.value, customerId));`,
          `    ${kw('return')} order;`,
          `  }`,
          '',
          `  ${fn('cancel')}()${op(':')} ${kw('void')} {`,
          `    ${cm('// Invariante del dominio — no se puede cancelar si ya fue enviado')}`,
          `    ${kw('if')} (${kw('this')}.status === ${st('"SHIPPED"')}) ${kw('throw new')} ${fn('DomainError')}(${st('"Cannot cancel a shipped order"')});`,
          `    ${kw('this')}.status = ${st('"CANCELLED"')};`,
          `    ${kw('this')}.${fn('record')}(${kw('new')} ${tp('OrderCancelledEvent')}(${kw('this')}.id.value));`,
          `  }`,
          '',
          `  ${fn('pullDomainEvents')}()${op(':')} ${tp('DomainEvent')}[] {`,
          `    ${kw('const')} events = [...${kw('this')}._events];`,
          `    ${kw('this')}._events = [];`,
          `    ${kw('return')} events;`,
          `  }`,
          '',
          `  ${kw('private')} ${fn('record')}(e${op(':')} ${tp('DomainEvent')})${op(':')} ${kw('void')} { ${kw('this')}._events.${fn('push')}(e); }`,
          `}`,
        ].join('\n'),
      },
