        id: 'value-objects',
        label: 'Money.ts',
        path: 'src/domain/value-objects/Money.ts',
        concept: { label: 'Dominio: Value Objects', href: '#dominio' },
        code: [
          cm('// Value Object: igualdad por valor, inmutable, se valida en el constructor'),
          `${kw('export class')} ${tp('Money')} {`,
          `  ${kw('private')} ${fn('constructor')}(`,
          `    ${kw('public readonly')} amount${op(':')}   ${tp('number')},`,
          `    ${kw('public readonly')} currency${op(':')} ${tp('string')},`,
          `  ) {}`,
          '',
          `  ${kw('static')} ${fn('of')}(amount${op(':')} ${tp('number')}, currency${op(':')} ${tp('string')})${op(':')} ${tp('Money')} {`,
          `    ${kw('if')} (amount < ${nm('0')}) ${kw('throw new')} ${fn('DomainError')}(${st('"Amount cannot be negative"')});`,
          `    ${kw('if')} (!currency.${fn('trim')}()) ${kw('throw new')} ${fn('DomainError')}(${st('"Currency required"')});`,
          `    ${kw('return new')} ${tp('Money')}(amount, currency.${fn('toUpperCase')}());`,
          `  }`,
          '',
          `  ${fn('add')}(other${op(':')} ${tp('Money')})${op(':')} ${tp('Money')} {`,
          `    ${kw('if')} (${kw('this')}.currency !== other.currency) ${kw('throw new')} ${fn('DomainError')}(${st('"Currency mismatch"')});`,
          `    ${kw('return')} ${tp('Money')}.${fn('of')}(${kw('this')}.amount + other.amount, ${kw('this')}.currency);`,
          `  }`,
          '',
          `  ${fn('equals')}(other${op(':')} ${tp('Money')})${op(':')} ${tp('boolean')} {`,
          `    ${kw('return')} ${kw('this')}.amount === other.amount && ${kw('this')}.currency === other.currency;`,
          `  }`,
          `}`,
          '',
          cm('// OrderId — Value Object para identidad fuertemente tipada'),
          `${kw('export class')} ${tp('OrderId')} {`,
          `  ${kw('private')} ${fn('constructor')}(${kw('public readonly')} value${op(':')} ${tp('string')}) {}`,
          `  ${kw('static')} ${fn('generate')}()${op(':')} ${tp('OrderId')} { ${kw('return new')} ${tp('OrderId')}(${fn('uuidv4')}()); }`,
          `  ${fn('equals')}(other${op(':')} ${tp('OrderId')})${op(':')} ${tp('boolean')} { ${kw('return')} ${kw('this')}.value === other.value; }`,
          `}`,
        ].join('\n'),
