---
const kw = (s: string) => `<span class="token-kw">${s}</span>`;
const fn = (s: string) => `<span class="token-fn">${s}</span>`;
const tp = (s: string) => `<span class="token-tp">${s}</span>`;
const cm = (s: string) => `<span class="token-cm">${s}</span>`;
const op = (s: string) => `<span class="token-op">${s}</span>`;
const st = (s: string) => `<span class="token-str">${s}</span>`;
const nm = (s: string) => `<span class="token-num">${s}</span>`;

interface ConceptLink { label: string; href: string; }
interface FileEntry { id: string; label: string; path: string; concept: ConceptLink; code: string; }
interface Group { id: string; label: string; colorClass: string; dotClass: string; files: FileEntry[]; }

