          `    ${kw('if')} (${kw('this')}.state === ${st('"OPEN"')}) {`,
          `      ${kw('if')} (${fn('Date')}.${fn('now')}() - ${kw('this')}.lastFail < ${kw('this')}.timeout)`,
          `        ${kw('throw new')} ${fn('Error')}(${st('"Circuit OPEN"')});`,
          `      ${kw('this')}.state = ${st('"HALF_OPEN"')};`,
          `    }`,
          `    ${kw('try')} {`,
          `      ${kw('const')} r = ${kw('await')} ${fn('fn')}(${kw('this')}.svc);`,
          `      ${kw('this')}.failures = ${nm('0')}; ${kw('this')}.state = ${st('"CLOSED"')};`,
          `      ${kw('return')} r;`,
          `    } ${kw('catch')} (err) {`,
          `      ${kw('this')}.lastFail = ${fn('Date')}.${fn('now')}();`,
          `      ${kw('if')} (++${kw('this')}.failures >= ${kw('this')}.threshold) ${kw('this')}.state = ${st('"OPEN"')};`,
          `      ${kw('throw')} err;`,
          `    }`,
          `  }`,
          `}`,
