          `        ${kw('await')} ${kw('this')}.goldRepo.${fn('insert')}(result.record!);`,
          `        ${kw('await')} ${kw('this')}.store.${fn('markPromoted')}(record);`,
          `      } ${kw('else if')} (record.retryCount >= record.maxRetries) {`,
          `        ${kw('await')} ${kw('this')}.store.${fn('markDeadLetter')}(record);`,
          `      } ${kw('else')} {`,
          `        ${kw('await')} ${kw('this')}.store.${fn('incrementRetry')}(record);`,
          `      }`,
          `    }`,
          `  }`,
          `}`,
        ].join('\n'),
      },
      {
        id: 'gold-projector',
        label: 'GoldProjector.ts',
        path: 'src/analytics/gold/GoldProjector.ts',
        concept: { label: 'Data Lake: Gold', href: '#datalake' },
        code: [
          cm('// App Service — proyecta Silver a Gold (star schema con RLS)'),
          `${kw('export class')} ${tp('GoldProjector')} {`,
          `  ${kw('constructor')}(`,
          `    ${kw('private readonly')} facts${op(':')}      ${tp('FactRepository')},`,
          `    ${kw('private readonly')} dimensions${op(':')} ${tp('DimensionRepository')},`,
          `  ) {}`,
          '',
          `  ${kw('async')} ${fn('project')}(event${op(':')} ${tp('CleanedEvent')})${op(':')} ${tp('Promise')}&lt;${kw('void')}&gt; {`,
          `    ${cm('// 1. Resolver o crear dimensiones')}`,
          `    ${kw('const')} dateKey     = ${fn('toDimDateKey')}(event.createdAt);`,
          `    ${kw('const')} customerKey = ${kw('await')} ${kw('this')}.dimensions.${fn('upsertCustomer')}({`,
          `      name${op(':')}   event.customerName,`,
          `      region${op(':')} event.customerRegion,`,
          `      tenantId${op(':')} event.tenantId,`,
          `    });`,
          '',
          `    ${cm('// 2. Insertar fact row con RLS')}`,
          `    ${kw('await')} ${kw('this')}.facts.${fn('insert')}({`,
          `      dateKey,`,
          `      customerKey,`,
          `      totalAmount${op(':')} event.totalEur,`,
          `      tenantId${op(':')}    event.tenantId, ${cm('// RLS column')}`,
          `    });`,
          `  }`,
          `}`,
        ].join('\n'),
      },
      {
        id: 'analytics-pipeline',
        label: 'AnalyticsPipeline.ts',
        path: 'src/analytics/pipeline/AnalyticsPipeline.ts',
        concept: { label: 'Data Lake: Pipeline', href: '#datalake' },
        code: [
          cm('// Orquestador end-to-end: Domain Event -> Bronze -> Silver -> Gold'),
          `${kw('export class')} ${tp('AnalyticsPipeline')} {`,
          `  ${kw('constructor')}(`,
          `    ${kw('private readonly')} bronze${op(':')}  ${tp('BronzeEventStore')},`,
          `    ${kw('private readonly')} gate1${op(':')}   ${tp('PromotionStrategy')}&lt;${tp('BronzeEvent')}, ${tp('CleanedEvent')}&gt;,`,
          `    ${kw('private readonly')} silver${op(':')}  ${tp('SilverEnricher')},`,
          `    ${kw('private readonly')} gate2${op(':')}   ${tp('PromotionStrategy')}&lt;${tp('CleanedEvent')}, ${tp('GoldFact')}&gt;,`,
          `    ${kw('private readonly')} gold${op(':')}    ${tp('GoldProjector')},`,
          `    ${kw('private readonly')} copper${op(':')}  ${tp('CopperStore')},`,
          `  ) {}`,
          '',
          `  ${kw('async')} ${fn('ingest')}(event${op(':')} ${tp('DomainEvent')}, tenant${op(':')} ${tp('string')})${op(':')} ${tp('Promise')}&lt;${kw('void')}&gt; {`,
          `    ${cm('// Bronze — siempre append')}`,
          `    ${kw('const')} raw = ${fn('toBronze')}(event, tenant);`,
          `    ${kw('await')} ${kw('this')}.bronze.${fn('append')}(raw);`,
          '',
          `    ${cm('// Gate 1 — schema + dedup')}`,
          `    ${kw('const')} g1 = ${kw('await')} ${kw('this')}.gate1.${fn('evaluate')}(raw);`,
          `    ${kw('if')} (g1.status === ${st("'quarantined'")}) ${kw('return')};`,
          '',
          `    ${cm('// Silver — enrich')}`,
          `    ${kw('const')} cleaned = ${kw('await')} ${kw('this')}.silver.${fn('process')}(raw);`,
          `    ${kw('if')} (!cleaned) ${kw('return')};`,
          '',
          `    ${cm('// Gate 2 — integrity + enrich check')}`,
          `    ${kw('const')} g2 = ${kw('await')} ${kw('this')}.gate2.${fn('evaluate')}(cleaned);`,
          `    ${kw('if')} (g2.status === ${st("'parked'")}) {`,
          `      ${kw('await')} ${kw('this')}.copper.${fn('park')}(cleaned, g2.failedRules);`,
          `      ${kw('return')};`,
          `    }`,
          '',
          `    ${cm('// Gold — project to star schema')}`,
          `    ${kw('await')} ${kw('this')}.gold.${fn('project')}(cleaned);`,
          `  }`,
          `}`,
        ].join('\n'),
      },
    ],
  },
];

const allFiles = groups.flatMap(g => g.files.map(f => ({ ...f, groupId: g.id })));
---

<section id="codigo" class="max-w-7xl mx-auto px-6 py-24 reveal">
  <h2 class="text-3xl font-extrabold mb-2 tracking-tight">Explorador de Código</h2>
  <p class="text-slate-400 mb-8 text-lg">
    Cada archivo está vinculado al concepto que ilustra. Selecciona un archivo en el árbol para ver su rol dentro de la arquitectura.
  </p>

  <div class="flex min-h-[28rem] flex-col md:min-h-[35rem] md:flex-row bg-slate-900 border border-slate-700 rounded-xl overflow-hidden">

    <!-- Left: file tree -->
    <div class="max-h-72 overflow-auto md:max-h-none md:w-52 lg:w-60 xl:w-64 shrink-0 border-b md:border-b-0 md:border-r border-slate-700 bg-slate-950/60">
      <div class="px-4 py-3 border-b border-slate-700/50">
        <span class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Archivos</span>
      </div>
      {groups.map(group => (
        <div class="py-2">
          <div class={`px-4 py-1 text-xs font-bold uppercase tracking-widest opacity-80 ${group.colorClass}`}>
            {group.label}
          </div>
          {group.files.map(f => (
            <button
              class="file-tree-item w-full text-left px-4 py-1.5 text-xs text-slate-400 hover:text-slate-100 hover:bg-slate-800/60 flex items-center gap-2 transition-colors"
              data-file={f.id}
            >
              <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${group.dotClass}`}></span>
              <span class="font-mono truncate">{f.label}</span>
            </button>
          ))}
        </div>
      ))}
    </div>

    <!-- Right: code viewer -->
    <div class="flex-1 min-w-0 flex flex-col">
      {allFiles.map((f, i) => (
        <div class={`code-panel flex flex-col flex-1 ${i === 0 ? '' : 'hidden'}`} data-panel={f.id}>
          <!-- Top bar: path + concept link -->
          <div class="flex flex-wrap items-center gap-3 px-5 py-3 border-b border-slate-700/60 bg-slate-900/80 shrink-0">
            <span class="min-w-0 flex-1 font-mono text-xs text-slate-500 truncate">{f.path}</span>
            <a
              href={f.concept.href}
              class="text-xs font-semibold px-3 py-1 rounded-full bg-slate-700 hover:bg-slate-600 text-slate-200 transition-colors text-center whitespace-normal sm:whitespace-nowrap shrink-0"
            >
              Ver concepto: {f.concept.label} &rarr;
            </a>
          </div>
          <!-- Code -->
          <pre class="p-4 sm:p-5 overflow-auto text-[11px] sm:text-xs leading-loose flex-1 m-0"><code set:html={f.code} /></pre>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  var treeItems = document.querySelectorAll('.file-tree-item');
  var panels    = document.querySelectorAll('.code-panel');

  function selectFile(id) {
    treeItems.forEach(function(btn) {
      var active = btn.dataset.file === id;
      btn.classList.toggle('text-slate-100', active);
      btn.classList.toggle('bg-slate-800', active);
      btn.classList.toggle('text-slate-400', !active);
    });
    panels.forEach(function(p) {
      p.classList.toggle('hidden', p.dataset.panel !== id);
    });
  }

  var first = treeItems[0];
  if (first) selectFile(first.dataset.file);

  treeItems.forEach(function(btn) {
    btn.addEventListener('click', function() { selectFile(this.dataset.file); });
  });
</script>
