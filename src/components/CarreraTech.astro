        <rect x="220" y="410" width="140" height="50" rx="8" fill="#0c1929" stroke="#3b82f6" stroke-width="1.5" class="cursor-pointer hover:fill-[#152540]" data-role="project-manager"/>
        <text x="290" y="432" text-anchor="middle" fill="#60a5fa" font-size="10" font-weight="600">Project Manager</text>
        <text x="290" y="448" text-anchor="middle" fill="#60a5fa80" font-size="8">Planificación, Riesgos</text>

        <rect x="380" y="410" width="140" height="50" rx="8" fill="#0c1929" stroke="#3b82f6" stroke-width="1.5" class="cursor-pointer hover:fill-[#152540]" data-role="business-analyst"/>
        <text x="450" y="432" text-anchor="middle" fill="#60a5fa" font-size="10" font-weight="600">Business Analyst</text>
        <text x="450" y="448" text-anchor="middle" fill="#60a5fa80" font-size="8">Requisitos, BPMN</text>

        <!-- ── ARCHITECT (convergence) ── -->
        <rect x="720" y="120" width="200" height="60" rx="10" fill="#1c1006" stroke="#f97316" stroke-width="2" class="cursor-pointer hover:fill-[#2a1a0a]" data-role="arquitecto"/>
        <text x="820" y="145" text-anchor="middle" fill="#fb923c" font-size="11" font-weight="700">Arquitecto de Software</text>
        <text x="820" y="162" text-anchor="middle" fill="#fb923c80" font-size="8">Decisiones, trade-offs, ADRs</text>

        <!-- Convergence arrows to Architect -->
        <line x1="680" y1="75" x2="720" y2="135" stroke="#22d3ee" stroke-width="1" stroke-dasharray="4,3" marker-end="url(#arr-career)"/>
        <line x1="680" y1="145" x2="720" y2="145" stroke="#f59e0b" stroke-width="1.5" marker-end="url(#arr-career)"/>
        <line x1="680" y1="215" x2="720" y2="155" stroke="#22c55e" stroke-width="1" stroke-dasharray="4,3" marker-end="url(#arr-career)"/>

        <!-- Label: multiple paths -->
        <text x="820" y="200" text-anchor="middle" fill="#fb923c60" font-size="8" font-style="italic">Se llega desde cualquier track senior</text>

        <!-- Years indicator -->
        <line x1="60" y1="490" x2="920" y2="490" stroke="#334155" stroke-width="1"/>
        <text x="150" y="510" text-anchor="middle" fill="#475569" font-size="9">0 - 2 años</text>
        <text x="370" y="510" text-anchor="middle" fill="#475569" font-size="9">2 - 5 años</text>
        <text x="590" y="510" text-anchor="middle" fill="#475569" font-size="9">5 - 8 años</text>
        <text x="820" y="510" text-anchor="middle" fill="#475569" font-size="9">8+ años</text>

        <defs>
          <marker id="arr-career" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
            <path d="M0,1 L8,4 L0,7 Z" fill="#94a3b8"/>
          </marker>
        </defs>
      </svg>
    </div>
  </div>

  <!-- Track filter -->
  <div class="mb-8">
    <h3 class="text-lg font-bold text-white mb-4">Detalle por rol</h3>
    <div class="flex gap-2 flex-wrap" id="track-filters">
      <button class="track-filter px-3 py-1.5 rounded-full text-xs font-mono bg-slate-700 text-white" data-track="all">Todos</button>
      {tracks.map(t => (
        <button class={`track-filter px-3 py-1.5 rounded-full text-xs font-mono bg-slate-800 ${t.color} hover:bg-slate-700 transition-colors`} data-track={t.id}>
          {t.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Role cards -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4" id="role-cards">
    {roles.map(role => (
      <div class={`role-card ${role.color} border ${role.borderColor} rounded-xl p-5 transition-all`} data-track={role.track} data-role-card={role.id}>
        <div class="flex items-center justify-between mb-3">
          <h4 class="font-bold text-white text-sm">{role.title}</h4>
          <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">{role.salaryRange}</span>
        </div>
        <p class="text-xs text-slate-300 mb-4">{role.description}</p>

        <div class="mb-3">
          <div class="text-xs font-mono text-slate-500 mb-1.5">Skills clave</div>
          <div class="flex flex-wrap gap-1">
            {role.skills.map(s => (
              <span class="text-xs bg-slate-800/80 text-slate-300 px-2 py-0.5 rounded">{s}</span>
            ))}
          </div>
        </div>

        <div class="mb-3">
          <div class="text-xs font-mono text-slate-500 mb-1.5">Herramientas</div>
          <div class="flex flex-wrap gap-1">
            {role.tools.map(t => (
              <span class="text-xs bg-slate-900 text-slate-400 px-2 py-0.5 rounded">{t}</span>
            ))}
          </div>
        </div>

        <div>
          <div class="text-xs font-mono text-slate-500 mb-1.5">Siguiente paso</div>
          <div class="flex flex-wrap gap-1">
            {role.nextSteps.map(n => (
              <span class="text-xs text-amber-400/80">→ {n}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  // Track filter
  document.getElementById('track-filters')?.addEventListener('click', function(e) {
    var btn = (e.target as HTMLElement).closest('.track-filter') as HTMLElement;
    if (!btn) return;
    var track = btn.dataset.track;

    // Update button styles
    document.querySelectorAll('.track-filter').forEach(function(b) {
      b.classList.remove('bg-slate-700', 'text-white');
      b.classList.add('bg-slate-800');
    });
    btn.classList.add('bg-slate-700', 'text-white');
    btn.classList.remove('bg-slate-800');

    // Filter cards
    document.querySelectorAll('.role-card').forEach(function(card) {
      if (track === 'all' || (card as HTMLElement).dataset.track === track) {
        (card as HTMLElement).style.display = '';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  });

  // SVG role hover -> highlight card
  document.querySelectorAll('[data-role]').forEach(function(el) {
    el.addEventListener('click', function() {
      var roleId = (el as HTMLElement).dataset.role;
      var card = document.querySelector('[data-role-card="' + roleId + '"]') as HTMLElement;
      if (card) {
        // Show all cards first
        document.querySelectorAll('.role-card').forEach(function(c) {
          (c as HTMLElement).style.display = '';
        });
        // Reset filter buttons
        document.querySelectorAll('.track-filter').forEach(function(b) {
          b.classList.remove('bg-slate-700', 'text-white');
          b.classList.add('bg-slate-800');
        });
        (document.querySelector('.track-filter[data-track="all"]') as HTMLElement)?.classList.add('bg-slate-700', 'text-white');

        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        card.classList.add('ring-2', 'ring-white/50');
        setTimeout(function() { card.classList.remove('ring-2', 'ring-white/50'); }, 2000);
      }
    });
  });
</script>
