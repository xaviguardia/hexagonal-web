---
const kw = (s) => `<span class="text-purple-400">${s}</span>`;
const fn = (s) => `<span class="text-yellow-300">${s}</span>`;
const tp = (s) => `<span class="text-cyan-300">${s}</span>`;
const cm = (s) => `<span class="text-slate-500">${s}</span>`;
const st = (s) => `<span class="text-emerald-300">${s}</span>`;
const nm = (s) => `<span class="text-slate-200">${s}</span>`;
const er = (s) => `<span class="text-red-400">${s}</span>`;
const ok = (s) => `<span class="text-green-400">${s}</span>`;

const patterns = [
  {
    id: 'unit-of-work',
    title: 'Unit of Work',
    badge: 'Transacción local',
    scope: 'Una base de datos',
    description: 'Cuando un use case debe guardar múltiples agregados de forma atómica. Si falla uno, todo se revierte. El Unit of Work agrupa las operaciones en una sola transacción sin que el dominio sepa nada de commits.',
    problem: [
      er('// PROBLEMA: dos saves independientes'),
      cm('// Si el segundo falla, el primero ya se ejecutó'),
      '',
      `${kw('class')} ${tp('ConfirmOrderService')} {`,
      `  ${kw('async')} ${fn('execute')}(${nm('orderId')}: ${tp('string')}) {`,
      `    ${kw('const')} ${nm('order')} = ${kw('await')} ${kw('this')}.${nm('orderRepo')}.${fn('findById')}(${nm('orderId')});`,
      `    ${nm('order')}.${fn('confirm')}();`,
      `    ${kw('await')} ${kw('this')}.${nm('orderRepo')}.${fn('save')}(${nm('order')});`,
      er('    // Si esto falla: pedido confirmado pero stock no reducido'),
      `    ${kw('await')} ${kw('this')}.${nm('stockRepo')}.${fn('reduce')}(${nm('order')}.items);`,
      `  }`,
      `}`,
    ].join('\n'),
    solution: [
      ok('// SOLUCION: Unit of Work como puerto de salida'),
      '',
      cm('// domain/ports/output.ports.ts'),
      `${kw('interface')} ${tp('UnitOfWork')} {`,
      `  ${fn('begin')}(): ${tp('Promise<void>')};`,
      `  ${fn('commit')}(): ${tp('Promise<void>')};`,
      `  ${fn('rollback')}(): ${tp('Promise<void>')};`,
      `  ${nm('orders')}: ${tp('OrderRepository')};`,
      `  ${nm('stock')}: ${tp('StockRepository')};`,
      `}`,
      '',
      `${kw('class')} ${tp('ConfirmOrderService')} {`,
      `  ${kw('async')} ${fn('execute')}(${nm('orderId')}: ${tp('string')}) {`,
      `    ${kw('await')} ${kw('this')}.${nm('uow')}.${fn('begin')}();`,
      `    ${kw('try')} {`,
      `      ${kw('const')} ${nm('order')} = ${kw('await')} ${kw('this')}.${nm('uow')}.${nm('orders')}.${fn('findById')}(${nm('orderId')});`,
      `      ${nm('order')}.${fn('confirm')}();`,
      `      ${kw('await')} ${kw('this')}.${nm('uow')}.${nm('orders')}.${fn('save')}(${nm('order')});`,
      `      ${kw('await')} ${kw('this')}.${nm('uow')}.${nm('stock')}.${fn('reduce')}(${nm('order')}.items);`,
      ok('      await this.uow.commit(); // atómico'),
      `    } ${kw('catch')} (${nm('e')}) {`,
      `      ${kw('await')} ${kw('this')}.${nm('uow')}.${fn('rollback')}();`,
      `      ${kw('throw')} ${nm('e')};`,
      `    }`,
      `  }`,
      `}`,
    ].join('\n'),
    insight: 'UnitOfWork es un puerto de salida más. El adaptador (PgUnitOfWork) maneja la transacción real con BEGIN/COMMIT/ROLLBACK. En tests, el adaptador en memoria simplemente ejecuta todo sin transacción real.',
    diagram: [
      { label: 'Application Service', color: 'bg-amber-500/20 border-amber-500/40 text-amber-300' },
      { label: 'Unit of Work (puerto)', color: 'bg-blue-500/20 border-blue-500/40 text-blue-300' },
      { label: 'OrderRepository', color: 'bg-slate-700 border-slate-600 text-slate-300' },
      { label: 'StockRepository', color: 'bg-slate-700 border-slate-600 text-slate-300' },
      { label: 'PostgreSQL Transaction', color: 'bg-green-500/20 border-green-500/40 text-green-300' },
    ],
  },
  {
    id: 'outbox',
    title: 'Outbox Pattern',
    badge: 'Eventos + BD atómicos',
    scope: 'BD + Message Broker',
    description: 'Guardar el pedido en BD y publicar el evento en Kafka/RabbitMQ en la misma operación atómica. El Outbox evita el "doble write" donde el pedido se guarda pero el evento no se publica (o viceversa).',
    problem: [
      er('// PROBLEMA: doble write no atómico'),
      cm('// Si falla la publicación del evento: inconsistencia'),
      '',
      `${kw('class')} ${tp('CreateOrderService')} {`,
      `  ${kw('async')} ${fn('execute')}(${nm('cmd')}) {`,
      `    ${kw('const')} ${nm('order')} = ${tp('Order')}.${fn('create')}(${nm('cmd')});`,
      `    ${kw('await')} ${kw('this')}.${nm('repo')}.${fn('save')}(${nm('order')});`,
      er('    // La BD está OK pero Kafka puede fallar aqui'),
      `    ${kw('await')} ${kw('this')}.${nm('eventBus')}.${fn('publish')}(${kw('new')} ${tp('OrderCreatedEvent')}(${nm('order')}));`,
      er('    // Resultado: orden guardada, evento perdido'),
      `  }`,
      `}`,
    ].join('\n'),
    solution: [
      ok('// SOLUCION: Outbox — evento guardado en la misma BD'),
      '',
      cm('// El pedido y el evento se guardan en la misma transacción'),
      `${kw('class')} ${tp('CreateOrderService')} {`,
      `  ${kw('async')} ${fn('execute')}(${nm('cmd')}) {`,
      `    ${kw('const')} ${nm('order')} = ${tp('Order')}.${fn('create')}(${nm('cmd')});`,
      '',
      `    ${kw('await')} ${kw('this')}.${nm('uow')}.${fn('begin')}();`,
      `    ${kw('await')} ${kw('this')}.${nm('uow')}.${nm('orders')}.${fn('save')}(${nm('order')});`,
      ok('    // Evento va a tabla "outbox", misma transacción'),
      `    ${kw('await')} ${kw('this')}.${nm('uow')}.${nm('outbox')}.${fn('store')}({`,
      `      type: ${st('"OrderCreated"')}, payload: ${nm('order')}`,
      `    });`,
      `    ${kw('await')} ${kw('this')}.${nm('uow')}.${fn('commit')}(); `,
      '',
      cm('    // Proceso separado publica la tabla outbox a Kafka'),
      cm('    // y marca los eventos como publicados'),
      `  }`,
      `}`,
      '',
      cm('// outbox_events (tabla BD):'),
      cm('// id | type | payload | published_at | created_at'),
    ].join('\n'),
    insight: 'El dominio solo llama a outbox.store() — no sabe nada de Kafka. Un worker independiente lee la tabla outbox y publica los eventos garantizando "at least once delivery". El dominio permanece limpio.',
    diagram: [
      { label: 'Application Service', color: 'bg-amber-500/20 border-amber-500/40 text-amber-300' },
      { label: 'Unit of Work', color: 'bg-blue-500/20 border-blue-500/40 text-blue-300' },
      { label: 'orders table', color: 'bg-slate-700 border-slate-600 text-slate-300' },
      { label: 'outbox_events table', color: 'bg-slate-700 border-slate-600 text-slate-300' },
      { label: 'Outbox Worker -> Kafka', color: 'bg-purple-500/20 border-purple-500/40 text-purple-300' },
    ],
  },
  {
    id: 'saga',
    title: 'Saga Pattern',
    badge: 'Transacciones distribuidas',
    scope: 'Múltiples servicios',
    description: 'Cuando una operación de negocio cruza varios microservicios. No existe transacción ACID distribuida. La Saga coordina una secuencia de transacciones locales con compensaciones si algo falla.',
    problem: [
      er('// PROBLEMA: transacción distribuida imposible'),
      cm('// Confirmar pedido requiere: OrderService + PaymentService + InventoryService'),
      '',
      er('// No existe BEGIN/COMMIT que abarque 3 bases de datos distintas'),
      er('// Si Payment falla tras confirmar Order: inconsistencia total'),
      '',
      `${kw('class')} ${tp('ConfirmOrderService')} {`,
      `  ${kw('async')} ${fn('execute')}(${nm('orderId')}) {`,
      `    ${kw('await')} ${kw('this')}.${nm('orderService')}.${fn('confirm')}(${nm('orderId')});`,
      er('    await this.paymentService.charge(orderId); // puede fallar'),
      er('    await this.inventoryService.reserve(orderId); // o este'),
      er('    // No hay forma de deshacer todo de forma atómica'),
      `  }`,
      `}`,
    ].join('\n'),
    solution: [
      ok('// SOLUCION: Saga Coreografiada por eventos'),
      '',
      cm('// Cada servicio escucha un evento y emite el siguiente'),
      '',
      `${cm('// 1. OrderService')}`,
      `${nm('order')}.${fn('confirm')}() => ${fn('emit')}(${kw('new')} ${tp('OrderConfirmedEvent')})`,
      '',
      `${cm('// 2. PaymentService escucha OrderConfirmed')}`,
      `${kw('on')}(${tp('OrderConfirmedEvent')}) => ${fn('charge')}() => ${fn('emit')}(${kw('new')} ${tp('PaymentProcessedEvent')})`,
      `${cm('                           => si falla: emit(new PaymentFailedEvent)')  }`,
      '',
      `${cm('// 3. InventoryService escucha PaymentProcessed')}`,
      `${kw('on')}(${tp('PaymentProcessedEvent')}) => ${fn('reserve')}() => ${fn('emit')}(${kw('new')} ${tp('OrderReadyEvent')})`,
      '',
      cm('// Compensación: si Inventory falla'),
      `${kw('on')}(${tp('InventoryFailedEvent')}) => ${nm('paymentService')}.${fn('refund')}()`,
      `                          => ${nm('orderService')}.${fn('cancel')}()`,
      '',
      ok('// Cada servicio tiene transacción local + Outbox Pattern'),
      ok('// La consistencia es eventual, no inmediata'),
    ].join('\n'),
    insight: 'En hexagonal, los eventos de dominio son el mecanismo. Cada servicio expone puertos de entrada para sus comandos y puertos de salida para publicar eventos. La Saga es la coreografia entre esos puertos.',
    diagram: [
      { label: 'OrderService (confirm)', color: 'bg-amber-500/20 border-amber-500/40 text-amber-300' },
      { label: 'OrderConfirmed event', color: 'bg-purple-500/20 border-purple-500/40 text-purple-300' },
      { label: 'PaymentService (charge)', color: 'bg-blue-500/20 border-blue-500/40 text-blue-300' },
      { label: 'PaymentProcessed event', color: 'bg-purple-500/20 border-purple-500/40 text-purple-300' },
      { label: 'InventoryService (reserve)', color: 'bg-green-500/20 border-green-500/40 text-green-300' },
    ],
  },
];
---

<section id="transaccionalidad" class="py-24 px-6 max-w-6xl mx-auto reveal">
  <div class="text-center mb-16">
    <span class="text-xs font-mono text-purple-400 uppercase tracking-widest">Transacciónalidad</span>
    <h2 class="text-3xl font-bold text-white mt-3 mb-4">Patrónes de consistencia</h2>
    <p class="text-slate-400 max-w-2xl mx-auto">
      La arquitectura hexagonal define puertos para la consistencia transacciónal.
      Según el alcance de la operación, el patrón es diferente.
    </p>
  </div>

  <!-- Scope selector visual -->
  <div class="grid md:grid-cols-3 gap-4 mb-12">
    {patterns.map((p, i) => (
      <button
        class="trans-tab text-left p-4 rounded-xl border transition-all"
        data-tab={p.id}
        class:list={[
          i === 0
            ? 'bg-purple-500/20 border-purple-500/50'
            : 'bg-slate-800/60 border-slate-700 hover:border-slate-500'
        ]}
      >
        <div class="flex items-center justify-between mb-2">
          <span class:list={['font-bold text-sm', i === 0 ? 'text-purple-300' : 'text-slate-300']}>{p.title}</span>
          <span class="text-xs px-2 py-0.5 rounded-full bg-slate-700 text-slate-400 font-mono">{p.scope}</span>
        </div>
        <p class:list={['text-xs', i === 0 ? 'text-purple-400/80' : 'text-slate-500']}>{p.badge}</p>
      </button>
    ))}
  </div>

  {patterns.map((p, i) => (
    <div class="trans-panel" data-panel={p.id} style={i !== 0 ? 'display:none' : ''}>
      <div class="mb-6">
        <div class="flex items-center gap-3 flex-wrap">
          <h3 class="text-white font-bold text-lg">{p.title}</h3>
          <span class="text-xs px-2 py-1 rounded-full bg-purple-500/20 border border-purple-500/40 text-purple-300 font-mono">{p.scope}</span>
        </div>
        <p class="text-slate-400 mt-2 text-sm leading-relaxed max-w-3xl">{p.description}</p>
      </div>

      <!-- Diagrama de flujo -->
      <div class="mb-6 flex items-center gap-2 flex-wrap">
        {p.diagram.map((d, di) => (
          <div class="flex items-center gap-2">
            <div class:list={['px-3 py-1.5 rounded-lg border text-xs font-mono', d.color]}>
              {d.label}
            </div>
            {di < p.diagram.length - 1 && (
              <span class="text-slate-600 text-lg">&#8594;</span>
            )}
          </div>
        ))}
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-red-500"></span>
            <span class="text-red-400 text-sm font-semibold uppercase tracking-wide">Sin patrón</span>
          </div>
          <div class="bg-slate-950 rounded-xl border border-red-900/40 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2 bg-slate-900 border-b border-red-900/40">
              <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/40"></span>
              <span class="text-slate-500 text-xs font-mono ml-2">inconsistencia potencial</span>
            </div>
            <pre class="p-4 text-sm font-mono leading-relaxed overflow-x-auto"><code set:html={p.problem} /></pre>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-purple-500"></span>
            <span class="text-purple-400 text-sm font-semibold uppercase tracking-wide">Con {p.title}</span>
          </div>
          <div class="bg-slate-950 rounded-xl border border-purple-900/40 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2 bg-slate-900 border-b border-purple-900/40">
              <span class="w-3 h-3 rounded-full bg-red-500/40"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
              <span class="w-3 h-3 rounded-full bg-purple-500/70"></span>
              <span class="text-slate-500 text-xs font-mono ml-2">consistente</span>
            </div>
            <pre class="p-4 text-sm font-mono leading-relaxed overflow-x-auto"><code set:html={p.solution} /></pre>
          </div>
        </div>
      </div>

      <div class="mt-6 bg-purple-500/10 border border-purple-500/30 rounded-xl p-5">
        <p class="text-purple-200 text-sm leading-relaxed">
          <span class="font-semibold text-purple-400">Principio: </span>{p.insight}
        </p>
      </div>
    </div>
  ))}

  <!-- Tabla comparativa -->
  <div class="mt-16 overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-800">
          <th class="text-left py-3 pr-6 text-slate-400 font-medium">Patrón</th>
          <th class="text-left py-3 pr-6 text-slate-400 font-medium">Alcance</th>
          <th class="text-left py-3 pr-6 text-slate-400 font-medium">Consistencia</th>
          <th class="text-left py-3 text-slate-400 font-medium">Complejidad</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-slate-800/50">
          <td class="py-3 pr-6 text-amber-400 font-mono">Unit of Work</td>
          <td class="py-3 pr-6 text-slate-300">Una BD</td>
          <td class="py-3 pr-6 text-green-400">Inmediata (ACID)</td>
          <td class="py-3 text-slate-400">Baja</td>
        </tr>
        <tr class="border-b border-slate-800/50">
          <td class="py-3 pr-6 text-purple-400 font-mono">Outbox Pattern</td>
          <td class="py-3 pr-6 text-slate-300">BD + Message Broker</td>
          <td class="py-3 pr-6 text-yellow-400">Eventual (at-least-once)</td>
          <td class="py-3 text-slate-400">Media</td>
        </tr>
        <tr>
          <td class="py-3 pr-6 text-blue-400 font-mono">Saga</td>
          <td class="py-3 pr-6 text-slate-300">Múltiples servicios</td>
          <td class="py-3 pr-6 text-orange-400">Eventual + compensación</td>
          <td class="py-3 text-slate-400">Alta</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<script>
  var tabs = document.querySelectorAll('.trans-tab');
  var panels = document.querySelectorAll('.trans-panel');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.getAttribute('data-tab');
      tabs.forEach(function(t) {
        t.className = 'trans-tab text-left p-4 rounded-xl border transition-all bg-slate-800/60 border-slate-700 hover:border-slate-500';
        t.querySelector('.font-bold').className = 'font-bold text-sm text-slate-300';
        t.querySelector('.text-xs:last-child').className = 'text-xs text-slate-500';
      });
      tab.className = 'trans-tab text-left p-4 rounded-xl border transition-all bg-purple-500/20 border-purple-500/50';
      tab.querySelector('.font-bold').className = 'font-bold text-sm text-purple-300';
      tab.querySelector('.text-xs:last-child').className = 'text-xs text-purple-400/80';
      panels.forEach(function(p) {
        p.style.display = p.getAttribute('data-panel') === target ? '' : 'none';
      });
    });
  });
</script>
