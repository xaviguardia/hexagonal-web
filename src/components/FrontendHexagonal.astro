---
const kw = (s) => `<span class="text-purple-400">${s}</span>`;
const fn = (s) => `<span class="text-yellow-300">${s}</span>`;
const tp = (s) => `<span class="text-cyan-300">${s}</span>`;
const cm = (s) => `<span class="text-slate-500">${s}</span>`;
const st = (s) => `<span class="text-emerald-300">${s}</span>`;
const nm = (s) => `<span class="text-slate-200">${s}</span>`;
const er = (s) => `<span class="text-red-400">${s}</span>`;
const ok = (s) => `<span class="text-green-400">${s}</span>`;

const tabs = [
  {
    id: 'fe-hexagon',
    label: 'Hexágono Frontend',
  },
  {
    id: 'validaciones',
    label: 'Validaciones',
  },
  {
    id: 'metadata-ui',
    label: 'Metadata-Driven UI',
  },
];

const mobileHexagonFlow = [
  {
    title: 'Backend',
    accent: 'text-amber-300',
    border: 'border-amber-500/30',
    bg: 'bg-amber-500/10',
    bullets: [
      'Dominio de negocio y reglas criticas',
      'Casos de uso de backend',
      'HTTP API y persistencia como adaptadores',
    ],
  },
  {
    title: 'Contrato compartido',
    accent: 'text-emerald-300',
    border: 'border-emerald-500/30',
    bg: 'bg-emerald-500/10',
    bullets: [
      'DTOs y FormSchema',
      'Validaciones de formato reutilizables',
      'El backend dice que datos y restricciones existen',
    ],
  },
  {
    title: 'Frontend',
    accent: 'text-fuchsia-300',
    border: 'border-fuchsia-500/30',
    bg: 'bg-fuchsia-500/10',
    bullets: [
      'Dominio UI, sin reglas de negocio',
      'Use cases de pantalla y hooks',
      'React, Vue o fetch como adaptadores',
    ],
  },
];

const hookCode = [
  cm('// PRIMARY ADAPTER — el hook conecta React con el use case'),
  cm('// No contiene lógica, solo ciclo de vida'),
  `${kw('function')} ${fn('usePedidoForm')}(${nm('id')}) {`,
  `  ${kw('const')} [${nm('state')}, ${nm('setState')}] = ${fn('useState')}(${kw('null')});`,
  `  ${kw('const')} [${nm('errors')}, ${nm('setErrors')}] = ${fn('useState')}({});`,
  ``,
  `  ${fn('useEffect')}(() => {`,
  `    ${kw('new')} ${tp('LoadPedidoFormUseCase')}(`,
  `      ${kw('new')} ${tp('HttpPedidoRepository')}(),`,
  `      ${kw('new')} ${tp('HttpFormSchemaRepository')}(),`,
  `    ).${fn('execute')}(${nm('id')}).${fn('then')}(${nm('setState')});`,
  `  }, [${nm('id')}]);`,
  ``,
  `  ${kw('const')} ${fn('save')} = ${kw('async')} (${nm('data')}) => {`,
  `    ${kw('try')} {`,
  `      ${kw('await')} ${kw('new')} ${tp('SavePedidoUseCase')}(${kw('new')} ${tp('HttpPedidoRepository')}()).${fn('execute')}(${nm('data')});`,
  `    } ${kw('catch')} (${nm('e')}) {`,
  `      ${kw('if')} (${nm('e')} ${kw('instanceof')} ${tp('ApiDomainError')}) ${fn('setErrors')}({ [${nm('e')}.field]: ${nm('e')}.message });`,
  `    }`,
  `  };`,
  ``,
  `  ${kw('return')} { ${nm('state')}, ${nm('errors')}, ${fn('save')} };`,
  `}`,
  ``,
  cm('// COMPONENTE — solo renderiza, sin lógica'),
  `${kw('function')} ${fn('PedidoEditPage')}({ ${nm('id')} }) {`,
  `  ${kw('const')} { ${nm('state')}, ${nm('errors')}, ${fn('save')} } = ${fn('usePedidoForm')}(${nm('id')});`,
  `  ${kw('if')} (!${nm('state')}) ${kw('return')} <${tp('Spinner')} />;`,
  `  ${kw('return')} <${tp('DynamicForm')} ${nm('schema')}={${nm('state')}.${nm('schema')}} ${nm('data')}={${nm('state')}.${nm('data')}} ${nm('errors')}={${nm('errors')}} ${nm('onSave')}={${fn('save')}} />;`,
  `}`,
].join('\n');

const useCaseCode = [
  cm('// APPLICATION LAYER — pure TypeScript, sin React, sin fetch'),
  cm('// Completamente testable con Jest sin montar componentes'),
  `${kw('class')} ${tp('LoadPedidoFormUseCase')} {`,
  `  ${kw('constructor')}(`,
  `    ${kw('private')} ${nm('pedidoRepo')}: ${tp('PedidoRepository')},`,
  `    ${kw('private')} ${nm('schemaRepo')}: ${tp('FormSchemaRepository')},`,
  `  ) {}`,
  ``,
  `  ${kw('async')} ${fn('execute')}(${nm('id')}: ${tp('string')}): ${tp('Promise<PedidoFormState>')} {`,
  `    ${kw('const')} [${nm('data')}, ${nm('schema')}] = ${kw('await')} ${tp('Promise')}.${fn('all')}([`,
  `      ${kw('this')}.${nm('pedidoRepo')}.${fn('findById')}(${nm('id')}),`,
  `      ${kw('this')}.${nm('schemaRepo')}.${fn('getSchemaForPedido')}(${st("'edicion'")})`,
  `    ]);`,
  `    ${kw('return')} { ${nm('data')}, ${nm('schema')}, ${nm('errors')}: {}, ${nm('status')}: ${st("'idle'")} };`,
  `  }`,
  `}`,
  ``,
  cm('// SECONDARY ADAPTER — implementa el puerto con fetch'),
  `${kw('class')} ${tp('HttpPedidoRepository')} ${kw('implements')} ${tp('PedidoRepository')} {`,
  `  ${kw('async')} ${fn('save')}(${nm('pedido')}: ${tp('PedidoDto')}): ${tp('Promise<void>')} {`,
  `    ${kw('const')} ${nm('res')} = ${kw('await')} ${fn('fetch')}(${st('`/api/pedidos/${pedido.id}`')}, {`,
  `      ${nm('method')}: ${st("'PUT'")}, ${nm('body')}: ${tp('JSON')}.${fn('stringify')}(${nm('pedido')})`,
  `    });`,
  `    ${kw('if')} (!${nm('res')}.${nm('ok')}) {`,
  `      ${kw('const')} ${nm('err')} = ${kw('await')} ${nm('res')}.${fn('json')}();`,
  `      ${kw('throw')} ${kw('new')} ${tp('ApiDomainError')}(${nm('err')}.${nm('code')}, ${nm('err')}.${nm('message')}, ${nm('err')}.${nm('field')});`,
  `    }`,
  `  }`,
  `}`,
].join('\n');

const validacionesCode = [
  cm('// FRONTEND: validación de formato/UX solamente'),
  cm('// Zod schema compartido con el backend (paquete contracts/)'),
  `${kw('const')} ${nm('PedidoSchema')} = ${nm('z')}.${fn('object')}({`,
  `  ${nm('clienteId')}: ${nm('z')}.${fn('string')}().${fn('uuid')}(),`,
  `  ${nm('importe')}: ${nm('z')}.${fn('number')}().${fn('positive')}(),`,
  ok(`  // SOLO formato — las reglas de negocio estan en el backend`),
  `});`,
  ``,
  cm('// BACKEND: las reglas de negocio viven en el dominio'),
  `${kw('class')} ${tp('Pedido')} {`,
  `  ${fn('confirmar')}() {`,
  `    ${kw('if')} (${kw('this')}.${nm('estado')} !== ${st("'borrador'")}) {`,
  `      ${kw('throw')} ${kw('new')} ${tp('DomainError')}(${st("'ESTADO_INVALIDO'")}, ...);`,
  `    }`,
  `    ${kw('if')} (${kw('this')}.${nm('cliente')}.${nm('creditoSuperado')}) {`,
  `      ${kw('throw')} ${kw('new')} ${tp('DomainError')}(${st("'CREDITO_SUPERADO'")}, ...);`,
  `    }`,
  `    ${kw('if')} (${kw('this')}.${nm('lineas')}.${nm('length')} === 0) {`,
  `      ${kw('throw')} ${kw('new')} ${tp('DomainError')}(${st("'SIN_LINEAS'")}, ...);`,
  `    }`,
  `  }`,
  `}`,
  ``,
  cm('// ADAPTER HTTP: traduce excepciones a errores estructurados'),
  `} ${kw('catch')} (${nm('e')}) {`,
  `  ${kw('if')} (${nm('e')} ${kw('instanceof')} ${tp('DomainError')}) {`,
  `    ${nm('res')}.${fn('status')}(422).${fn('json')}({`,
  `      ${nm('code')}: ${nm('e')}.${nm('code')},`,
  `      ${nm('message')}: ${nm('e')}.${nm('message')},`,
  `      ${nm('field')}: ${nm('e')}.${nm('field')},`,
  `    });`,
  `  }`,
  `}`,
].join('\n');

const metadataCode = [
  cm('// Use Case como Form Configuration Provider'),
  cm('// Decide qué control usar según el contexto'),
  `${kw('class')} ${tp('GetPedidoSchemaUseCase')} {`,
  `  ${fn('execute')}(${nm('context')}: ${st("'alta'")} | ${st("'edicion'")}): ${tp('FormSchema')} {`,
  `    ${kw('return')} {`,
  `      ${nm('fields')}: [`,
  `        {`,
  `          ${nm('name')}: ${st("'clienteId'")}, ${nm('type')}: ${st("'lookup'")},`,
  `          ${nm('label')}: ${st("'Cliente'")},`,
  `          ${nm('relation')}: {`,
  `            ${nm('entity')}: ${st("'clientes'")},`,
  `            ${nm('displayField')}: ${st("'razonSocial'")},`,
  `            ${nm('searchPort')}: ${st("'/api/clientes/search'")}`,
  `          }`,
  `        },`,
  `        {`,
  `          ${nm('name')}: ${st("'lineas'")}, ${nm('type')}: ${st("'grid'")},`,
  `          ${nm('label')}: ${st("'Líneas de pedido'")},`,
  `          ${nm('relation')}: {`,
  `            ${nm('columns')}: [`,
  `              { ${nm('name')}: ${st("'articuloId'")}, ${nm('type')}: ${st("'lookup'")}, ${nm('relation')}: { ${nm('entity')}: ${st("'articulos'")} } },`,
  `              { ${nm('name')}: ${st("'cantidad'")},   ${nm('type')}: ${st("'number'")} },`,
  `              { ${nm('name')}: ${st("'precio'")},     ${nm('type')}: ${st("'number'")}, ${nm('readonly')}: ${kw('true')} },`,
  `            ]`,
  `          }`,
  `        },`,
  `        {`,
  `          ${nm('name')}: ${st("'etiquetas'")}, ${nm('type')}: ${st("'multiselect'")},`,
  `          ${nm('label')}: ${st("'Etiquetas'")},`,
  `          ${nm('relation')}: { ${nm('entity')}: ${st("'etiquetas'")}, ${nm('searchPort')}: ${st("'/api/etiquetas'")} }`,
  `        }`,
  `      ]`,
  `    };`,
  `  }`,
  `}`,
  ``,
  cm('// FRONTEND: renderer genérico, no hardcodea campos'),
  `${kw('function')} ${fn('renderField')}(${nm('meta')}, ${nm('value')}) {`,
  `  ${kw('switch')} (${nm('meta')}.${nm('type')}) {`,
  `    ${kw('case')} ${st("'lookup'")}:      ${kw('return')} <${tp('LookupField')}     ${nm('meta')}={${nm('meta')}} ${nm('value')}={${nm('value')}} />;`,
  `    ${kw('case')} ${st("'grid'")}:        ${kw('return')} <${tp('EditableGrid')}    ${nm('meta')}={${nm('meta')}} ${nm('value')}={${nm('value')}} />;`,
  `    ${kw('case')} ${st("'multiselect'")}: ${kw('return')} <${tp('MultiSelect')}     ${nm('meta')}={${nm('meta')}} ${nm('value')}={${nm('value')}} />;`,
  `    ${kw('default')}:            ${kw('return')} <${tp('TextField')}       ${nm('meta')}={${nm('meta')}} ${nm('value')}={${nm('value')}} />;`,
  `  }`,
  `}`,
].join('\n');
---

<section id="frontend-hexagonal" class="py-20 px-6 max-w-6xl mx-auto reveal">
  <div class="text-center mb-12">
    <span class="text-xs font-mono text-purple-400 uppercase tracking-widest">Aplicación real</span>
    <h2 class="text-3xl font-bold text-white mt-2">Frontend Hexagonal</h2>
    <p class="text-slate-400 mt-3 max-w-2xl mx-auto">
      El frontend tiene su propio hexágono. Los componentes son adapters primarios, los hooks son use cases, y fetch es un adapter secundario.
    </p>
  </div>

  <!-- Dual Hexagon Diagram -->
  <div class="mb-16">
    <h3 class="text-xl font-bold text-purple-400 mb-6 text-center">Dos hexágonos, un solo dominio de negocio</h3>
    <p class="text-slate-400 text-sm text-center max-w-3xl mx-auto mb-8">
      El backend posee las reglas de negocio. El frontend tiene su propio hexágono pero <strong class="text-white">no duplica el dominio</strong>:
      modela comportamiento UI (qué campos mostrar, cómo renderizarlos, estado del formulario).
      La metadata-driven UI es el puente — el backend <strong class="text-white">dice qué</strong>, el frontend <strong class="text-white">decide cómo</strong>.
    </p>

    <div class="grid gap-4 md:hidden">
      {mobileHexagonFlow.map((item, index) => (
        <>
          <article class={`rounded-xl border p-4 ${item.bg} ${item.border}`}>
            <h4 class={`text-sm font-semibold ${item.accent}`}>{item.title}</h4>
            <ul class="mt-3 space-y-2 text-sm text-slate-300">
              {item.bullets.map((bullet) => (
                <li class="rounded-lg border border-slate-800 bg-slate-950/70 px-3 py-2">{bullet}</li>
              ))}
            </ul>
          </article>
          {index < mobileHexagonFlow.length - 1 && (
            <div class="text-center text-xs font-mono uppercase tracking-[0.2em] text-slate-500">↓</div>
          )}
        </>
      ))}

      <div class="rounded-xl border border-slate-700 bg-slate-900/70 p-4 text-sm text-slate-300">
        El backend sigue siendo la fuente de verdad. El frontend interpreta la metadata y modela la experiencia
        de usuario sin reimplementar las invariantes del dominio.
      </div>
    </div>

    <div class="hidden md:block bg-slate-900 border border-slate-700 rounded-xl p-6 md:p-8 overflow-x-auto">
      <svg viewBox="0 0 900 480" class="w-full" style="min-width: 700px; max-height: 480px;">
        <!-- ═══ BACKEND HEXAGON (left) ═══ -->
        <!-- Infra layer -->
        <polygon points="200,30 350,115 350,285 200,370 50,285 50,115"
          fill="#1e1b4b" stroke="#8b5cf6" stroke-width="1.5" opacity="0.6"/>
        <!-- App layer -->
        <polygon points="200,65 320,135 320,265 200,335 80,265 80,135"
          fill="#0f1f3d" stroke="#3b82f6" stroke-width="1.5" opacity="0.6"/>
        <!-- Domain layer -->
        <polygon points="200,105 280,155 280,245 200,295 120,245 120,155"
          fill="#1c1408" stroke="#f59e0b" stroke-width="2"/>

        <!-- Backend labels -->
        <text x="200" y="185" text-anchor="middle" fill="#fbbf24" font-size="11" font-weight="700">DOMINIO</text>
        <text x="200" y="200" text-anchor="middle" fill="#fbbf24" font-size="11" font-weight="700">DE NEGOCIO</text>
        <text x="200" y="218" text-anchor="middle" fill="#fbbf2480" font-size="8">Pedido, Cliente, Stock</text>
        <text x="200" y="232" text-anchor="middle" fill="#fbbf2480" font-size="8">Invariantes, Domain Events</text>

        <text x="200" y="320" text-anchor="middle" fill="#93c5fd" font-size="9" font-weight="600">APLICACIÓN</text>
        <text x="200" y="333" text-anchor="middle" fill="#93c5fd80" font-size="7">CreatePedidoUseCase</text>
        <text x="200" y="345" text-anchor="middle" fill="#93c5fd80" font-size="7">GetPedidoSchemaUseCase</text>

        <text x="200" y="363" text-anchor="middle" fill="#c4b5fd" font-size="8" font-weight="600">INFRAESTRUCTURA</text>
        <text x="108" y="130" text-anchor="middle" fill="#c4b5fd80" font-size="7">PostgreSQL</text>
        <text x="292" y="130" text-anchor="middle" fill="#c4b5fd80" font-size="7">HTTP API</text>

        <text x="200" y="20" text-anchor="middle" fill="#8b5cf6" font-size="12" font-weight="700">BACKEND</text>

        <!-- Star on domain = source of truth -->
        <text x="200" y="253" text-anchor="middle" fill="#fbbf24" font-size="9">★ Fuente de verdad</text>

        <!-- ═══ FRONTEND HEXAGON (right) ═══ -->
        <!-- Infra layer -->
        <polygon points="700,30 850,115 850,285 700,370 550,285 550,115"
          fill="#1e1b4b" stroke="#a855f7" stroke-width="1.5" opacity="0.6"/>
        <!-- App layer -->
        <polygon points="700,65 820,135 820,265 700,335 580,265 580,135"
          fill="#1a0f2e" stroke="#c084fc" stroke-width="1.5" opacity="0.6"/>
        <!-- UI Domain layer -->
        <polygon points="700,105 780,155 780,245 700,295 620,245 620,155"
          fill="#1a0a2e" stroke="#e879f9" stroke-width="2"/>

        <!-- Frontend labels -->
        <text x="700" y="185" text-anchor="middle" fill="#e879f9" font-size="11" font-weight="700">DOMINIO UI</text>
        <text x="700" y="200" text-anchor="middle" fill="#e879f9" font-size="11" font-weight="700">(no negocio)</text>
        <text x="700" y="218" text-anchor="middle" fill="#e879f980" font-size="8">FormSchema, FieldMeta</text>
        <text x="700" y="232" text-anchor="middle" fill="#e879f980" font-size="8">State machines, UI rules</text>

        <text x="700" y="320" text-anchor="middle" fill="#c084fc" font-size="9" font-weight="600">APLICACIÓN</text>
        <text x="700" y="333" text-anchor="middle" fill="#c084fc80" font-size="7">LoadPedidoFormUseCase</text>
        <text x="700" y="345" text-anchor="middle" fill="#c084fc80" font-size="7">SavePedidoUseCase</text>

        <text x="700" y="363" text-anchor="middle" fill="#a855f780" font-size="8" font-weight="600">ADAPTADORES UI</text>
        <text x="608" y="130" text-anchor="middle" fill="#a855f780" font-size="7">React/Vue</text>
        <text x="792" y="130" text-anchor="middle" fill="#a855f780" font-size="7">fetch / WS</text>

        <text x="700" y="20" text-anchor="middle" fill="#a855f7" font-size="12" font-weight="700">FRONTEND</text>

        <!-- No business rules indicator -->
        <text x="700" y="253" text-anchor="middle" fill="#e879f9" font-size="9">✗ Sin reglas de negocio</text>

        <!-- ═══ CONNECTION: API + FormSchema ═══ -->
        <!-- Main arrow: HTTP API -->
        <line x1="350" y1="175" x2="550" y2="175" stroke="#22c55e" stroke-width="2" marker-end="url(#arr-conn)"/>
        <rect x="385" y="158" width="130" height="18" rx="4" fill="#0f172a" stroke="#22c55e" stroke-width="1"/>
        <text x="450" y="171" text-anchor="middle" fill="#4ade80" font-size="8" font-weight="600">HTTP API (datos)</text>

        <!-- Metadata arrow: FormSchema -->
        <line x1="350" y1="225" x2="550" y2="225" stroke="#f59e0b" stroke-width="2" stroke-dasharray="6,3" marker-end="url(#arr-meta)"/>
        <rect x="375" y="208" width="150" height="18" rx="4" fill="#1c1408" stroke="#f59e0b" stroke-width="1"/>
        <text x="450" y="221" text-anchor="middle" fill="#fbbf24" font-size="8" font-weight="600">FormSchema (metadata)</text>

        <!-- Validation error arrow back -->
        <line x1="550" y1="260" x2="350" y2="260" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arr-err)"/>
        <rect x="390" y="248" width="120" height="15" rx="3" fill="#450a0a" stroke="#ef4444" stroke-width="0.5"/>
        <text x="450" y="259" text-anchor="middle" fill="#ef4444" font-size="7">DomainError (422)</text>

        <!-- ═══ BOTTOM: Key insight boxes ═══ -->
        <!-- Backend domain box -->
        <rect x="30" y="400" width="340" height="65" rx="10" fill="#1c1408" stroke="#f59e0b" stroke-width="1.5"/>
        <text x="200" y="420" text-anchor="middle" fill="#fbbf24" font-size="10" font-weight="700">El backend POSEE el dominio</text>
        <text x="200" y="436" text-anchor="middle" fill="#fbbf2480" font-size="8">Reglas de negocio, invariantes, validaciones</text>
        <text x="200" y="450" text-anchor="middle" fill="#fbbf2480" font-size="8">de dominio. Solo existen aquí. Una sola vez.</text>

        <!-- Frontend domain box -->
        <rect x="530" y="400" width="340" height="65" rx="10" fill="#1a0a2e" stroke="#e879f9" stroke-width="1.5"/>
        <text x="700" y="420" text-anchor="middle" fill="#e879f9" font-size="10" font-weight="700">El frontend CONSUME metadata</text>
        <text x="700" y="436" text-anchor="middle" fill="#e879f980" font-size="8">FormSchema dice qué campos, qué tipos, qué</text>
        <text x="700" y="450" text-anchor="middle" fill="#e879f980" font-size="8">relaciones. El renderer genérico decide cómo.</text>

        <defs>
          <marker id="arr-conn" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
            <path d="M0,1 L8,4 L0,7 Z" fill="#22c55e"/>
          </marker>
          <marker id="arr-meta" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
            <path d="M0,1 L8,4 L0,7 Z" fill="#f59e0b"/>
          </marker>
          <marker id="arr-err" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
            <path d="M0,1 L8,4 L0,7 Z" fill="#ef4444"/>
          </marker>
        </defs>
      </svg>
    </div>

    <!-- Anti-pattern vs pattern -->
    <div class="grid md:grid-cols-2 gap-6 mt-8">
      <div class="bg-red-950/30 border border-red-500/30 rounded-xl p-6">
        <h4 class="font-bold text-red-400 mb-3">Anti-patrón: Sparsed Domain</h4>
        <ul class="space-y-2 text-sm text-slate-300">
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Reglas de negocio duplicadas en frontend y backend</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> El frontend valida "crédito superado" con su propia lógica</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Cambiar una regla requiere tocar dos repositorios</li>
          <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span> Discrepancias inevitables entre FE y BE</li>
        </ul>
      </div>
      <div class="bg-green-950/30 border border-green-500/30 rounded-xl p-6">
        <h4 class="font-bold text-green-400 mb-3">Patrón: Metadata-Driven UI</h4>
        <ul class="space-y-2 text-sm text-slate-300">
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Reglas de negocio solo en el dominio backend</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> El backend envía FormSchema con la estructura de campos</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> El frontend es un renderer genérico que interpreta metadata</li>
          <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span> Errores de dominio vuelven como DomainError estructurado (422)</li>
        </ul>
      </div>
    </div>

    <div class="mt-6 bg-slate-800/50 border border-purple-400/30 rounded-xl p-6">
      <h4 class="font-bold text-white mb-2">El flujo completo</h4>
      <ol class="space-y-2 text-sm text-slate-300 list-decimal list-inside">
        <li><strong class="text-amber-300">Backend</strong> define FormSchema en el Use Case: campos, tipos, relaciones, permisos</li>
        <li><strong class="text-purple-300">Frontend</strong> pide schema + datos via API → recibe metadata + data</li>
        <li><strong class="text-purple-300">Renderer genérico</strong> interpreta FieldMeta → lookup, grid, multiselect, etc.</li>
        <li>Usuario edita → frontend valida <strong class="text-slate-400">solo formato</strong> (Zod) → envía al backend</li>
        <li><strong class="text-amber-300">Dominio</strong> aplica invariantes → si falla, devuelve DomainError con code + field</li>
        <li><strong class="text-purple-300">Frontend</strong> muestra el error en el campo correcto — sin conocer la regla</li>
      </ol>
    </div>
  </div>

  <!-- Tabs -->
  <div class="flex gap-2 mb-8 flex-wrap" id="fe-tabs">
    {tabs.map((t, i) => (
      <button
        class={`fe-tab px-4 py-2 rounded font-mono text-sm transition-colors ${i === 0 ? 'bg-purple-600 text-white' : 'bg-slate-800 text-slate-400 hover:text-white'}`}
        data-tab={t.id}
      >
        {t.label}
      </button>
    ))}
  </div>

  <!-- Tab: Hexágono Frontend -->
  <div id="fe-hexagon" class="fe-panel">
    <div class="grid lg:grid-cols-2 gap-8 items-start">
      <!-- Diagrama -->
      <div class="space-y-2">
        <div class="rounded-lg border border-purple-500/30 bg-purple-500/5 p-4">
          <div class="text-xs font-mono text-purple-400 mb-2 uppercase">Primary Adapters (Driving)</div>
          <div class="text-sm text-slate-300">Componentes React/Vue/Angular</div>
          <div class="text-xs text-slate-500 mt-1">Solo renderizan y dispatchen — sin lógica</div>
        </div>
        <div class="flex justify-center text-slate-600">↓ llaman a</div>
        <div class="rounded-lg border border-cyan-500/30 bg-cyan-500/5 p-4">
          <div class="text-xs font-mono text-cyan-400 mb-2 uppercase">Application Layer</div>
          <div class="text-sm text-slate-300">Use Cases (hooks / servicios puros)</div>
          <div class="text-xs text-slate-500 mt-1">No conocen React ni fetch — 100% testables</div>
        </div>
        <div class="flex justify-center text-slate-600">↓ usa interfaces</div>
        <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/5 p-4">
          <div class="text-xs font-mono text-emerald-400 mb-2 uppercase">Domain (frontend)</div>
          <div class="text-sm text-slate-300">FormSchema, State machines, ValidationRules</div>
          <div class="text-xs text-slate-500 mt-1">NO duplica dominio backend — modela comportamiento UI</div>
        </div>
        <div class="flex justify-center text-slate-600">↓ implementado por</div>
        <div class="rounded-lg border border-amber-500/30 bg-amber-500/5 p-4">
          <div class="text-xs font-mono text-amber-400 mb-2 uppercase">Secondary Adapters (Driven)</div>
          <div class="text-sm text-slate-300">HttpRepository · LocalStorageRepo · WebSocket</div>
          <div class="text-xs text-slate-500 mt-1">Intercambiables sin tocar use cases</div>
        </div>
      </div>
      <!-- Código -->
      <div>
        <div class="text-xs font-mono text-slate-500 mb-2">Hook como adapter + Use Case puro</div>
        <pre class="bg-slate-950 rounded-lg p-4 text-xs font-mono overflow-x-auto border border-slate-800"><code set:html={hookCode} /></pre>
      </div>
    </div>

    <!-- Tabla de mapeo -->
    <div class="mt-8 overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-700">
            <th class="text-left py-2 px-3 text-slate-400 font-normal">Pieza</th>
            <th class="text-left py-2 px-3 text-slate-400 font-normal">Rol en hexagonal</th>
            <th class="text-left py-2 px-3 text-slate-400 font-normal">Ejemplo</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800">
          <tr><td class="py-2 px-3 text-purple-300 font-mono">Component</td><td class="py-2 px-3 text-slate-300">Adapter primario</td><td class="py-2 px-3 text-slate-500">PedidoEditPage, TaskInbox</td></tr>
          <tr><td class="py-2 px-3 text-purple-300 font-mono">Hook</td><td class="py-2 px-3 text-slate-300">Adapter primario / Use Case</td><td class="py-2 px-3 text-slate-500">usePedidoForm, useTaskList</td></tr>
          <tr><td class="py-2 px-3 text-cyan-300 font-mono">UseCase class</td><td class="py-2 px-3 text-slate-300">Application layer</td><td class="py-2 px-3 text-slate-500">LoadPedidoFormUseCase</td></tr>
          <tr><td class="py-2 px-3 text-emerald-300 font-mono">FormSchema</td><td class="py-2 px-3 text-slate-300">Domain model (UI)</td><td class="py-2 px-3 text-slate-500">FieldMeta, ColumnMeta</td></tr>
          <tr><td class="py-2 px-3 text-amber-300 font-mono">HttpRepository</td><td class="py-2 px-3 text-slate-300">Adapter secundario</td><td class="py-2 px-3 text-slate-500">HttpPedidoRepository</td></tr>
          <tr><td class="py-2 px-3 text-amber-300 font-mono">LocalStorageRepo</td><td class="py-2 px-3 text-slate-300">Adapter secundario</td><td class="py-2 px-3 text-slate-500">Borradores offline</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Tab: Validaciones -->
  <div id="validaciones" class="fe-panel hidden">
    <div class="grid lg:grid-cols-2 gap-8 items-start">
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-white">Dónde vive cada validación</h3>
        <div class="space-y-3">
          <div class="p-4 rounded-lg bg-slate-800/50 border border-slate-700">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-semibold text-purple-300">Frontend (UX)</span>
              <span class="text-xs text-slate-500">Zod / HTML5</span>
            </div>
            <p class="text-xs text-slate-400">Formato, campos requeridos, longitud máxima. Mejora experiencia pero NUNCA reemplaza backend.</p>
          </div>
          <div class="p-4 rounded-lg bg-slate-800/50 border border-slate-700">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-semibold text-cyan-300">Use Case (Aplicación)</span>
              <span class="text-xs text-slate-500">Precondiciones</span>
            </div>
            <p class="text-xs text-slate-400">Permisos del usuario, existencia de entidades relacionadas, contexto de operación.</p>
          </div>
          <div class="p-4 rounded-lg bg-slate-800/50 border border-emerald-500/30">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-semibold text-emerald-300">Dominio — fuente de verdad</span>
              <span class="text-xs text-emerald-600">UNICO punto</span>
            </div>
            <p class="text-xs text-slate-400">Invariantes de negocio: "pedido sin líneas", "crédito superado", "stock insuficiente". Solo aquí.</p>
          </div>
          <div class="p-4 rounded-lg bg-slate-800/50 border border-slate-700">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-semibold text-amber-300">DB Constraints</span>
              <span class="text-xs text-slate-500">Ultima defensa</span>
            </div>
            <p class="text-xs text-slate-400">UNIQUE, NOT NULL, FK. No depender de esto — es el último recurso.</p>
          </div>
        </div>

        <div class="mt-4 p-4 rounded-lg bg-blue-500/10 border border-blue-500/30">
          <div class="text-sm font-semibold text-blue-300 mb-2">Schema Sharing</div>
          <p class="text-xs text-slate-400">En monorepos, el schema de <strong>formato</strong> (Zod) se comparte entre FE y BE via un paquete <code class="text-blue-300">contracts/</code>. Las reglas de negocio NUNCA se comparten — solo existen en el dominio backend.</p>
        </div>
      </div>
      <div>
        <div class="text-xs font-mono text-slate-500 mb-2">Patrón completo de validaciones</div>
        <pre class="bg-slate-950 rounded-lg p-4 text-xs font-mono overflow-x-auto border border-slate-800"><code set:html={validacionesCode} /></pre>
      </div>
    </div>

    <div class="mt-8 overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-700">
            <th class="text-left py-2 px-3 text-slate-400 font-normal">Validación</th>
            <th class="text-left py-2 px-3 text-slate-400 font-normal">Capa</th>
            <th class="text-left py-2 px-3 text-slate-400 font-normal">Ejemplo</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800">
          <tr><td class="py-2 px-3 text-slate-300">Campo requerido</td><td class="py-2 px-3 text-purple-300">Frontend</td><td class="py-2 px-3 text-slate-500">z.string().min(1)</td></tr>
          <tr><td class="py-2 px-3 text-slate-300">Formato email</td><td class="py-2 px-3 text-purple-300">Frontend + Backend</td><td class="py-2 px-3 text-slate-500">z.string().email()</td></tr>
          <tr><td class="py-2 px-3 text-slate-300">Stock insuficiente</td><td class="py-2 px-3 text-emerald-300">Dominio</td><td class="py-2 px-3 text-slate-500">pedido.confirmar() throws</td></tr>
          <tr><td class="py-2 px-3 text-slate-300">Credito superado</td><td class="py-2 px-3 text-emerald-300">Dominio</td><td class="py-2 px-3 text-slate-500">cliente.puedeOperar()</td></tr>
          <tr><td class="py-2 px-3 text-slate-300">Usuario sin permiso</td><td class="py-2 px-3 text-cyan-300">Use Case</td><td class="py-2 px-3 text-slate-500">authService.canEdit()</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Tab: Metadata-Driven UI -->
  <div id="metadata-ui" class="fe-panel hidden">
    <div class="grid lg:grid-cols-2 gap-8 items-start">
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-white">FormSchema: el Use Case como configurador de formularios</h3>
        <p class="text-slate-400 text-sm">En un ERP, el Use Case devuelve no solo datos sino también <strong class="text-white">cómo editarlos</strong>. El frontend es un renderer genérico que interpreta el schema.</p>

        <div class="space-y-2">
          <div class="text-xs font-mono text-slate-500 uppercase mb-2">Tipos de control según semántica</div>
          <div class="grid grid-cols-2 gap-2">
            <div class="p-3 rounded bg-slate-800/50 border border-slate-700">
              <div class="text-xs font-mono text-purple-300">FK</div>
              <div class="text-xs text-slate-400 mt-1">→ lookup con búsqueda</div>
            </div>
            <div class="p-3 rounded bg-slate-800/50 border border-slate-700">
              <div class="text-xs font-mono text-purple-300">1:N</div>
              <div class="text-xs text-slate-400 mt-1">→ grid editable</div>
            </div>
            <div class="p-3 rounded bg-slate-800/50 border border-slate-700">
              <div class="text-xs font-mono text-purple-300">M:N</div>
              <div class="text-xs text-slate-400 mt-1">→ multiselect</div>
            </div>
            <div class="p-3 rounded bg-slate-800/50 border border-slate-700">
              <div class="text-xs font-mono text-purple-300">enum pequeño</div>
              <div class="text-xs text-slate-400 mt-1">→ select / radio</div>
            </div>
            <div class="p-3 rounded bg-slate-800/50 border border-slate-700">
              <div class="text-xs font-mono text-purple-300">boolean</div>
              <div class="text-xs text-slate-400 mt-1">→ checkbox / toggle</div>
            </div>
            <div class="p-3 rounded bg-slate-800/50 border border-slate-700">
              <div class="text-xs font-mono text-purple-300">texto largo</div>
              <div class="text-xs text-slate-400 mt-1">→ textarea / richtext</div>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/30">
          <div class="text-sm font-semibold text-emerald-300 mb-1">Beneficio clave</div>
          <p class="text-xs text-slate-400">Cambias el tipo de control en el Use Case sin tocar ningún componente. Cambias React por Vue sin tocar ningún Use Case. Las decisiones de presentación no contaminan el dominio.</p>
        </div>
      </div>
      <div>
        <div class="text-xs font-mono text-slate-500 mb-2">Use Case como Form Configuration Provider</div>
        <pre class="bg-slate-950 rounded-lg p-4 text-xs font-mono overflow-x-auto border border-slate-800"><code set:html={metadataCode} /></pre>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('fe-tabs').addEventListener('click', function(e) {
    var btn = e.target.closest('.fe-tab');
    if (!btn) return;
    var target = btn.dataset.tab;
    document.querySelectorAll('.fe-tab').forEach(function(b) {
      b.classList.remove('bg-purple-600', 'text-white');
      b.classList.add('bg-slate-800', 'text-slate-400');
    });
    btn.classList.add('bg-purple-600', 'text-white');
    btn.classList.remove('bg-slate-800', 'text-slate-400');
    document.querySelectorAll('.fe-panel').forEach(function(p) {
      p.classList.add('hidden');
    });
    var panel = document.getElementById(target);
    if (panel) panel.classList.remove('hidden');
  });
</script>
