---
const kw = (s) => `<span class="text-purple-400">${s}</span>`;
const fn = (s) => `<span class="text-yellow-300">${s}</span>`;
const tp = (s) => `<span class="text-cyan-300">${s}</span>`;
const cm = (s) => `<span class="text-slate-500">${s}</span>`;
const st = (s) => `<span class="text-emerald-300">${s}</span>`;
const nm = (s) => `<span class="text-slate-200">${s}</span>`;
const er = (s) => `<span class="text-red-400">${s}</span>`;
const ok = (s) => `<span class="text-green-400">${s}</span>`;

const adapters = [
  {
    id: 'tipos',
    title: 'Tipos de Adaptadores',
    badge: 'Primario vs Secundario',
    description: 'Los adaptadores primarios (driving) inician la conversacion con el dominio. Los secundarios (driven) son invocados por el dominio para satisfacer sus necesidades.',
    code: [
      cm('// ADAPTADORES PRIMARIOS (Driving / Inbound)'),
      cm('// Traducen el mundo exterior al lenguaje del dominio'),
      '',
      `${kw('class')} ${tp('HttpOrderController')} {        `,
      `  ${kw('async')} ${fn('createOrder')}(${nm('req')}, ${nm('res')}) {`,
      `    ${kw('const')} ${nm('cmd')} = ${kw('new')} ${tp('CreateOrderCommand')}(${nm('req')}.body);`,
      `    ${kw('const')} ${nm('order')} = ${kw('await')} ${kw('this')}.${nm('useCase')}.${fn('execute')}(${nm('cmd')});`,
      `    ${nm('res')}.${fn('json')}({ id: ${nm('order')}.id });`,
      `  }`,
      `}`,
      '',
      `${kw('class')} ${tp('KafkaOrderConsumer')} {     `,
      `  ${kw('async')} ${fn('onMessage')}(${nm('msg')}) {`,
      `    ${kw('const')} ${nm('cmd')} = ${tp('CreateOrderCommand')}.${fn('fromEvent')}(${nm('msg')}.value);`,
      `    ${kw('await')} ${kw('this')}.${nm('useCase')}.${fn('execute')}(${nm('cmd')});`,
      `  }`,
      `}`,
      '',
      cm('// ADAPTADORES SECUNDARIOS (Driven / Outbound)'),
      cm('// Implementan los puertos de salida que define el dominio'),
      '',
      `${kw('class')} ${tp('PgOrderRepository')} ${kw('implements')} ${tp('OrderRepository')} {`,
      `  ${kw('async')} ${fn('findById')}(${nm('id')}) {`,
      `    ${kw('const')} ${nm('row')} = ${kw('await')} ${kw('this')}.${nm('db')}.${fn('query')}(${st('`SELECT * FROM orders WHERE id=$1`')}, [${nm('id')}]);`,
      `    ${kw('return')} ${nm('row')} ? ${tp('Order')}.${fn('reconstitute')}(${nm('row')}) : ${kw('null')};`,
      `  }`,
      `}`,
      '',
      `${kw('class')} ${tp('SendGridEmailAdapter')} ${kw('implements')} ${tp('NotificationPort')} {`,
      `  ${kw('async')} ${fn('notifyOrderCreated')}(${nm('order')}) {`,
      `    ${kw('await')} ${kw('this')}.${nm('sendgrid')}.${fn('send')}({ to: ${nm('order')}.email, subject: ${st('"Pedido recibido"')} });`,
      `  }`,
      `}`,
    ].join('\n'),
    rule: 'La regla de dependencia: los adaptadores dependen del dominio, nunca al revés. El dominio define los puertos (interfaces), la infraestructura los implementa.',
  },
  {
    id: 'acl',
    title: 'Anti-Corruption Layer',
    badge: 'APIs externas',
    description: 'Cuando consumes un servicio externo (Stripe, Salesforce, un legado) con su propio modelo. El ACL traduce ese modelo a tus tipos de dominio, evitando que conceptos externos contaminen tu dominio.',
    code: [
      cm('// Sin ACL: el modelo externo invade el dominio'),
      er('import { StripeCustomer } from "stripe"; // tipo externo en dominio'),
      er('class OrderService {'),
      er('  constructor(private stripe: Stripe) {} // dependencia directa'),
      er('  async charge(order: Order, stripeCustomer: StripeCustomer) {}'),
      er('}'),
      '',
      ok('// Con ACL: el dominio define su propio contrato'),
      '',
      cm('// domain/ports/output.ports.ts — vocabulario del dominio'),
      `${kw('interface')} ${tp('PaymentPort')} {`,
      `  ${fn('charge')}(${nm('amount')}: ${tp('Money')}, ${nm('customerId')}: ${tp('CustomerId')}): ${tp('Promise<PaymentResult>')};`,
      `  ${fn('refund')}(${nm('paymentId')}: ${tp('PaymentId')}): ${tp('Promise<void>')};`,
      `}`,
      '',
      cm('// infrastructure/acl/StripePaymentAdapter.ts — el ACL'),
      `${kw('class')} ${tp('StripePaymentAdapter')} ${kw('implements')} ${tp('PaymentPort')} {`,
      `  ${kw('async')} ${fn('charge')}(${nm('amount')}: ${tp('Money')}, ${nm('customerId')}: ${tp('CustomerId')}) {`,
      cm('    // Traduce: Money -> Stripe amount (centimos)'),
      cm('    // Traduce: CustomerId -> Stripe customer_id'),
      `    ${kw('const')} ${nm('result')} = ${kw('await')} ${kw('this')}.${nm('stripe')}.paymentIntents.${fn('create')}({`,
      `      amount: ${nm('amount')}.inCents(),`,
      `      currency: ${nm('amount')}.currency.${fn('toLowerCase')}(),`,
      `      customer: ${nm('customerId')}.${fn('toString')}(),`,
      `    });`,
      cm('    // Traduce: Stripe response -> PaymentResult (dominio)'),
      `    ${kw('return')} ${kw('new')} ${tp('PaymentResult')}(${nm('result')}.id, ${nm('result')}.status === ${st('"succeeded"')});`,
      `  }`,
      `}`,
    ].join('\n'),
    rule: 'El ACL es el traductor entre dos lenguajes ubicuos. Si el servicio externo cambia su API, solo cambia el adaptador. El dominio ni se entera.',
  },
  {
    id: 'gateway',
    title: 'Gateway',
    badge: 'APIs externas complejas',
    description: 'Un adaptador especializado para servicios externos con autenticación, reintentos, paginación y mapeo de errores. El dominio recibe un contrato simple; el Gateway gestiona toda la complejidad.',
    code: [
      cm('// domain/ports/output.ports.ts — contrato simple'),
      `${kw('interface')} ${tp('InventoryPort')} {`,
      `  ${fn('getStock')}(${nm('productId')}: ${tp('ProductId')}): ${tp('Promise<number>')};`,
      `  ${fn('reserve')}(${nm('productId')}: ${tp('ProductId')}, ${nm('qty')}: ${tp('number')}): ${tp('Promise<void>')};`,
      `}`,
      '',
      cm('// infrastructure/gateway/InventoryGateway.ts'),
      `${kw('class')} ${tp('InventoryGateway')} ${kw('implements')} ${tp('InventoryPort')} {`,
      `  ${kw('private')} ${nm('baseUrl')} = ${st('"https://inventory-api.internal/v2"')};`,
      '',
      `  ${kw('async')} ${fn('getStock')}(${nm('productId')}: ${tp('ProductId')}) {`,
      `    ${kw('const')} ${nm('response')} = ${kw('await')} ${kw('this')}.${fn('fetchWithRetry')}(`,
      `      ${st('`${this.baseUrl}/products/${productId}/stock`')}`,
      `    );`,
      cm('    // Mapea respuesta externa a primitivo del dominio'),
      `    ${kw('return')} ${nm('response')}.data.availableUnits;`,
      `  }`,
      '',
      `  ${kw('private')} ${kw('async')} ${fn('fetchWithRetry')}(${nm('url')}: ${tp('string')}, ${nm('retries')} = 3) {`,
      `    ${kw('for')} (${kw('let')} ${nm('i')} = 0; ${nm('i')} < ${nm('retries')}; ${nm('i')}++) {`,
      `      ${kw('try')} {`,
      `        ${kw('const')} ${nm('res')} = ${kw('await')} ${fn('fetch')}(${nm('url')}, { headers: ${kw('this')}.${fn('authHeaders')}() });`,
      `        ${kw('if')} (!${nm('res')}.ok) ${kw('throw new')} ${tp('Error')}(${st('`HTTP ${res.status}`')});`,
      `        ${kw('return')} ${nm('res')}.${fn('json')}();`,
      `      } ${kw('catch')} (${nm('e')}) {`,
      `        ${kw('if')} (${nm('i')} === ${nm('retries')} - 1) ${kw('throw')} ${nm('e')};`,
      `        ${kw('await')} ${fn('sleep')}(${nm('i')} * 1000);`,
      `      }`,
      `    }`,
      `  }`,
      `}`,
    ].join('\n'),
    rule: 'El Gateway encapsula: autenticación, reintentos con backoff, mapeo de errores a excepciones del dominio, logging de llamadas externas. Todo invisible para el dominio.',
  },
  {
    id: 'circuit-breaker',
    title: 'Circuit Breaker',
    badge: 'Resiliencia',
    description: 'Si un servicio externo falla repetidamente, el Circuit Breaker abre el circuito y devuelve un fallback rápido. Evita acumular timeouts y protege el sistema cuando un dependiente está caído.',
    code: [
      cm('// infrastructure/adapters/ResilientInventoryAdapter.ts'),
      `${kw('type')} ${tp('State')} = ${st('"closed"')} | ${st('"open"')} | ${st('"half-open"')};`,
      '',
      `${kw('class')} ${tp('CircuitBreaker')} {`,
      `  ${kw('private')} ${nm('state')}: ${tp('State')} = ${st('"closed"')};`,
      `  ${kw('private')} ${nm('failures')} = 0;`,
      `  ${kw('private')} ${nm('lastFailure')} = 0;`,
      '',
      `  ${kw('async')} ${fn('execute')}(${nm('fn')}) {`,
      `    ${kw('if')} (${kw('this')}.${nm('state')} === ${st('"open"')}) {`,
      `      ${kw('if')} (${tp('Date')}.${fn('now')}() - ${kw('this')}.${nm('lastFailure')} > 30000) {`,
      `        ${kw('this')}.${nm('state')} = ${st('"half-open"')};`,
      `      } ${kw('else')} {`,
      er('        throw new Error("Circuit abierto — servicio no disponible");'),
      `      }`,
      `    }`,
      `    ${kw('try')} {`,
      `      ${kw('const')} ${nm('result')} = ${kw('await')} ${fn('fn')}();`,
      `      ${kw('this')}.${nm('failures')} = 0; ${kw('this')}.${nm('state')} = ${st('"closed"')};`,
      `      ${kw('return')} ${nm('result')};`,
      `    } ${kw('catch')} (${nm('e')}) {`,
      `      ${kw('this')}.${nm('failures')}++;`,
      `      ${kw('this')}.${nm('lastFailure')} = ${tp('Date')}.${fn('now')}();`,
      `      ${kw('if')} (${kw('this')}.${nm('failures')} >= 5) ${kw('this')}.${nm('state')} = ${st('"open"')};`,
      `      ${kw('throw')} ${nm('e')};`,
      `    }`,
      `  }`,
      `}`,
      '',
      cm('// Adaptador con Circuit Breaker'),
      `${kw('class')} ${tp('ResilientInventoryAdapter')} ${kw('implements')} ${tp('InventoryPort')} {`,
      `  ${kw('private')} ${nm('cb')} = ${kw('new')} ${tp('CircuitBreaker')}();`,
      '',
      `  ${kw('async')} ${fn('getStock')}(${nm('productId')}) {`,
      `    ${kw('try')} {`,
      `      ${kw('return')} ${kw('await')} ${kw('this')}.${nm('cb')}.${fn('execute')}(() => ${kw('this')}.${nm('gateway')}.${fn('getStock')}(${nm('productId')}));`,
      `    } ${kw('catch')} {`,
      ok('      return 0; // fallback: asumir sin stock si el servicio está caído'),
      `    }`,
      `  }`,
      `}`,
    ].join('\n'),
    rule: 'El Circuit Breaker es transparente para el dominio. Tres estados: Closed (normal), Open (falla rápida), Half-Open (prueba si recuperó). La lógica de fallback va en el adaptador.',
  },
];
---

<section id="infraestructura" class="py-24 px-6 max-w-6xl mx-auto reveal">
  <div class="text-center mb-16">
    <span class="text-xs font-mono text-orange-400 uppercase tracking-widest">Capa de Infraestructura</span>
    <h2 class="text-3xl font-bold text-white mt-3 mb-4">Adaptadores e integraciónes</h2>
    <p class="text-slate-400 max-w-2xl mx-auto">
      Los adaptadores son la capa que conecta el mundo real con el dominio. Aquí vive todo lo que puede cambiar:
      bases de datos, APIs externas, mensajería, caches.
    </p>
  </div>

  <!-- Tabs -->
  <div class="flex flex-wrap gap-3 justify-center mb-12">
    {adapters.map((a, i) => (
      <button
        class="infra-tab px-4 py-2 rounded-lg text-sm font-mono border transition-all"
        data-tab={a.id}
        class:list={[
          i === 0
            ? 'bg-orange-500/20 border-orange-500/50 text-orange-300'
            : 'bg-slate-800 border-slate-700 text-slate-400 hover:border-slate-500'
        ]}
      >
        {a.title}
      </button>
    ))}
  </div>

  {adapters.map((a, i) => (
    <div class="infra-panel" data-panel={a.id} style={i !== 0 ? 'display:none' : ''}>
      <div class="mb-6">
        <div class="flex items-center gap-3 mb-2 flex-wrap">
          <h3 class="text-white font-bold text-lg">{a.title}</h3>
          <span class="text-xs px-2 py-1 rounded-full bg-orange-500/20 border border-orange-500/40 text-orange-300 font-mono">{a.badge}</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed max-w-3xl">{a.description}</p>
      </div>

      <div class="bg-slate-950 rounded-xl border border-orange-900/40 overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2 bg-slate-900 border-b border-orange-900/40">
          <span class="w-3 h-3 rounded-full bg-red-500/40"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
          <span class="w-3 h-3 rounded-full bg-orange-500/70"></span>
          <span class="text-slate-500 text-xs font-mono ml-2">infrastructure/</span>
        </div>
        <pre class="p-4 text-sm font-mono leading-relaxed overflow-x-auto"><code set:html={a.code} /></pre>
      </div>

      <div class="mt-6 bg-orange-500/10 border border-orange-500/30 rounded-xl p-5">
        <p class="text-orange-200 text-sm leading-relaxed">
          <span class="font-semibold text-orange-400">Principio: </span>{a.rule}
        </p>
      </div>
    </div>
  ))}
</section>

<script>
  var tabs = document.querySelectorAll('.infra-tab');
  var panels = document.querySelectorAll('.infra-panel');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.getAttribute('data-tab');
      tabs.forEach(function(t) {
        t.className = 'infra-tab px-4 py-2 rounded-lg text-sm font-mono border transition-all bg-slate-800 border-slate-700 text-slate-400 hover:border-slate-500';
      });
      tab.className = 'infra-tab px-4 py-2 rounded-lg text-sm font-mono border transition-all bg-orange-500/20 border-orange-500/50 text-orange-300';
      panels.forEach(function(p) {
        p.style.display = p.getAttribute('data-panel') === target ? '' : 'none';
      });
    });
  });
</script>
