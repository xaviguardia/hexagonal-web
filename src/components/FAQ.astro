---
interface FAQItem {
  id: string;
  question: string;
  answer: string;
  diagram?: string;
}

const faqs: FAQItem[] = [
  {
    id: 'deuda-tecnica',
    question: '¿Qué es la deuda técnica?',
    answer: `
      <p class="mb-4">La <strong class="text-white">deuda técnica</strong> es una metáfora financiera inventada por <strong class="text-white">Ward Cunningham</strong> (1992). Funciona exactamente como una deuda monetaria:</p>

      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <div class="bg-slate-800/50 border border-blue-500/30 rounded-lg p-4">
          <div class="text-sm font-bold text-blue-400 mb-2">Deuda financiera</div>
          <ul class="text-xs space-y-1.5 text-slate-300">
            <li>Pides un préstamo → recibes dinero hoy</li>
            <li>Pagas <strong class="text-white">intereses</strong> cada mes</li>
            <li>Si no amortizas, los intereses crecen</li>
            <li>Si amortizas, dejas de pagar intereses</li>
          </ul>
        </div>
        <div class="bg-slate-800/50 border border-amber-500/30 rounded-lg p-4">
          <div class="text-sm font-bold text-amber-400 mb-2">Deuda técnica</div>
          <ul class="text-xs space-y-1.5 text-slate-300">
            <li>Tomas un atajo → entregas antes hoy</li>
            <li>Pagas <strong class="text-white">intereses</strong> en cada cambio futuro</li>
            <li>Si no refactorizas, cada cambio cuesta más</li>
            <li>Si refactorizas, recuperas velocidad</li>
          </ul>
        </div>
      </div>

      <div class="bg-slate-900 border border-slate-700 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-white mb-3">Ejemplo concreto</div>
        <div class="space-y-3 text-sm text-slate-300">
          <p>Tu equipo necesita entregar una feature para el viernes. Hay dos opciones:</p>
          <div class="grid md:grid-cols-2 gap-3">
            <div class="bg-green-950/30 border border-green-500/30 rounded-lg p-3">
              <div class="text-xs font-bold text-green-400 mb-1">Opción A: hacerlo bien (5 días)</div>
              <p class="text-xs text-slate-400">Crear un puerto, un adaptador, tests, separar responsabilidades. Tarda más, pero cada cambio futuro cuesta 1 hora.</p>
            </div>
            <div class="bg-amber-950/30 border border-amber-500/30 rounded-lg p-3">
              <div class="text-xs font-bold text-amber-400 mb-1">Opción B: atajo (2 días)</div>
              <p class="text-xs text-slate-400">Meter la lógica en el controller, hardcodear valores, sin tests. Entregas antes, pero cada cambio futuro cuesta 4 horas.</p>
            </div>
          </div>
          <p class="text-slate-400 text-xs">La opción B no es "mala" — es una <strong class="text-white">decisión consciente</strong>. El problema es cuando se acumula sin control y nadie "amortiza" (refactoriza).</p>
        </div>
      </div>

      <div class="mb-6">
        <div class="text-sm font-bold text-white mb-3">Tipos de deuda técnica (Martin Fowler)</div>
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-green-400 mb-1">Deliberada + Prudente</div>
            <p class="text-xs text-slate-400">"Sabemos que esto es un atajo, lo documentamos, y planificamos refactorizar en el sprint 12."</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-amber-400 mb-1">Deliberada + Imprudente</div>
            <p class="text-xs text-slate-400">"No tenemos tiempo para diseñar bien, ya lo arreglaremos" (spoiler: nunca se arregla).</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-blue-400 mb-1">Inadvertida + Prudente</div>
            <p class="text-xs text-slate-400">"Ahora que entendemos mejor el dominio, vemos que deberíamos haberlo modelado diferente."</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-red-400 mb-1">Inadvertida + Imprudente</div>
            <p class="text-xs text-slate-400">"¿Qué es una capa? Metemos todo en el controller." — falta de conocimiento, no decisión.</p>
          </div>
        </div>
      </div>

      <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-amber-300 mb-2">¿Cómo ayuda la arquitectura hexagonal?</div>
        <ul class="text-xs space-y-1.5 text-slate-300">
          <li><strong class="text-white">Puertos y adaptadores</strong> → cambiar tecnología (BD, framework) sin tocar el dominio = menos intereses</li>
          <li><strong class="text-white">Dominio aislado</strong> → las reglas de negocio no se "ensucian" con detalles técnicos = deuda crece más lento</li>
          <li><strong class="text-white">Tests sin infraestructura</strong> → refactorizar con red de seguridad = amortizar es más barato</li>
          <li><strong class="text-white">Inversión de dependencias</strong> → el dominio no depende de nada externo = puedes reemplazar piezas una a una</li>
        </ul>
      </div>

      <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
        <div class="text-sm font-bold text-white mb-2">La regla de oro</div>
        <p class="text-sm text-slate-300">La deuda técnica es inevitable y a veces necesaria. Lo peligroso no es tenerla, sino <strong class="text-white">no saber que la tienes</strong> o <strong class="text-white">no planificar cuándo amortizarla</strong>. Un equipo maduro la hace visible, la mide, y la paga antes de que los intereses paralicen el proyecto.</p>
      </div>
    `,
  },
  {
    id: 'software-legacy',
    question: '¿Qué es software legacy?',
    answer: `
      <p class="mb-4"><strong class="text-white">Software legacy</strong> (o "sistema heredado") es código que <strong class="text-white">funciona en producción, genera valor, pero da miedo tocarlo</strong>. No es un insulto — es una realidad que todo equipo enfrenta tarde o temprano.</p>

      <div class="bg-slate-800/50 border border-amber-500/30 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-amber-400 mb-2">La definición más honesta</div>
        <p class="text-sm text-slate-300 italic">"Legacy code is code without tests."</p>
        <p class="text-xs text-slate-500 mt-1">— Michael Feathers, <em>Working Effectively with Legacy Code</em> (2004)</p>
        <p class="text-sm text-slate-300 mt-3">Si no tiene tests, no puedes cambiarlo con confianza. Si no puedes cambiarlo con confianza, cada modificación es una ruleta rusa. Eso es legacy.</p>
      </div>

      <div class="mb-6">
        <div class="text-sm font-bold text-white mb-3">Señales de que estás ante software legacy</div>
        <div class="grid md:grid-cols-2 gap-3">
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-red-400 mb-1">Sin tests</div>
            <p class="text-xs text-slate-400">No hay tests automatizados, o los que hay están rotos y nadie los arregla. Los despliegues se hacen "cruzando los dedos".</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-red-400 mb-1">Nadie lo entiende completo</div>
            <p class="text-xs text-slate-400">La persona que lo escribió ya no está. La documentación (si existe) no se ha actualizado en años. Se aprende por arqueología.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-red-400 mb-1">Tecnología obsoleta</div>
            <p class="text-xs text-slate-400">Frameworks sin soporte, versiones de lenguaje EOL, librerías con vulnerabilidades conocidas. Actualizar da más miedo que dejarlo.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-red-400 mb-1">Acoplamiento extremo</div>
            <p class="text-xs text-slate-400">Todo depende de todo. Cambiar un campo en una tabla rompe tres pantallas, dos reports y un proceso batch que nadie sabía que existía.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-red-400 mb-1">Despliegues con miedo</div>
            <p class="text-xs text-slate-400">Solo se despliega los jueves (nunca viernes). Hay un "procedimiento de rollback" de 47 pasos. El equipo de ops tiene el teléfono siempre encendido.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-red-400 mb-1">Workarounds sobre workarounds</div>
            <p class="text-xs text-slate-400">Comentarios tipo "// no tocar esto, se rompe todo", "// hack temporal (2019)", "// TODO: arreglar cuando tengamos tiempo".</p>
          </div>
        </div>
      </div>

      <div class="bg-slate-900 border border-slate-700 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-white mb-3">La paradoja del legacy</div>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-green-950/30 border border-green-500/30 rounded-lg p-3">
            <div class="text-xs font-bold text-green-400 mb-1">Lo bueno</div>
            <p class="text-xs text-slate-300">Está en producción. Funciona. Genera dinero. Ha sobrevivido a mil cambios de requisitos. Es el sistema que paga las nóminas.</p>
          </div>
          <div class="bg-red-950/30 border border-red-500/30 rounded-lg p-3">
            <div class="text-xs font-bold text-red-400 mb-1">Lo malo</div>
            <p class="text-xs text-slate-300">Cada feature nueva tarda 5x más. Los bugs se multiplican. Los desarrolladores buenos huyen. La competencia te adelanta.</p>
          </div>
        </div>
        <p class="text-xs text-slate-400 mt-3">El peor error es reescribirlo desde cero. El segundo peor es no hacer nada. La respuesta correcta es <strong class="text-white">estrangularlo progresivamente</strong>.</p>
      </div>

      <div class="mb-6">
        <div class="text-sm font-bold text-white mb-3">Estrategias para modernizar legacy</div>
        <div class="space-y-3">
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-amber-400 mb-1">1. Strangler Fig Pattern</div>
            <p class="text-xs text-slate-300">Como una higuera que crece alrededor de un árbol viejo. Construyes funcionalidad nueva al lado del sistema legacy, redirigiendo tráfico gradualmente. Cuando la nueva pieza cubre toda la funcionalidad, retiras la vieja. Sin big bang, sin riesgo.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-blue-400 mb-1">2. Añadir tests antes de tocar</div>
            <p class="text-xs text-slate-300">Antes de modificar código legacy, escribe tests de caracterización: tests que documentan el comportamiento actual (aunque sea incorrecto). Ahora puedes refactorizar con red de seguridad. Es la técnica del libro de Michael Feathers.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-green-400 mb-1">3. Poner puertos en las costuras</div>
            <p class="text-xs text-slate-300">Identifica los puntos donde el sistema se conecta al exterior (BD, APIs, emails). Pon una interfaz (puerto) ahí. Ahora puedes reemplazar la implementación legacy por una nueva sin que el resto del sistema se entere. Arquitectura hexagonal aplicada a legacy.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-purple-400 mb-1">4. Anti-Corruption Layer</div>
            <p class="text-xs text-slate-300">Una capa de traducción entre el código nuevo y el legacy. El código nuevo habla en su propio lenguaje limpio, el ACL traduce al lenguaje del legacy. Protege al código nuevo de la "corrupción" del viejo modelo.</p>
          </div>
        </div>
      </div>

      <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-amber-300 mb-2">¿Cómo ayuda la arquitectura hexagonal?</div>
        <ul class="text-xs space-y-1.5 text-slate-300">
          <li><strong class="text-white">Puertos como costuras</strong> → identificas los puntos donde cortar y reemplazar piezas</li>
          <li><strong class="text-white">Adaptadores intercambiables</strong> → puedes tener el adaptador legacy y el nuevo funcionando en paralelo</li>
          <li><strong class="text-white">Dominio aislado</strong> → extraes reglas de negocio del código spaghetti a un dominio limpio y testable</li>
          <li><strong class="text-white">Tests sin infraestructura</strong> → añades tests al dominio sin necesitar la BD legacy</li>
        </ul>
      </div>

      <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
        <div class="text-sm font-bold text-white mb-2">La regla de oro</div>
        <p class="text-sm text-slate-300">Todo software exitoso se convierte en legacy. No es una cuestión de <em>si</em>, sino de <em>cuándo</em>. La diferencia entre un legacy manejable y uno catastrófico es si alguien pensó en tests, en desacoplar, y en documentar las decisiones importantes. Escribir buen código hoy es un regalo para el equipo del futuro.</p>
      </div>
    `,
  },
  {
    id: 'golden-master',
    question: '¿Qué es el Golden Master testing?',
    answer: `
      <p class="mb-4">El <strong class="text-white">Golden Master</strong> (también llamado <strong class="text-white">Approval Testing</strong> o <strong class="text-white">Snapshot Testing</strong>) es una técnica para poner bajo test código legacy <strong class="text-white">sin entender cómo funciona</strong>. Capturas la salida actual del sistema como "referencia dorada" y cualquier cambio futuro se compara contra ella.</p>

      <div class="bg-slate-900 border border-slate-700 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-white mb-3">La analogía</div>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-slate-800/50 border border-blue-500/30 rounded-lg p-3">
            <div class="text-xs font-bold text-blue-400 mb-1">Test clásico</div>
            <p class="text-xs text-slate-300">Tú escribes lo que esperas: <code class="text-blue-300">expect(total).toBe(150)</code>. Necesitas entender la lógica para saber que 150 es correcto.</p>
          </div>
          <div class="bg-slate-800/50 border border-amber-500/30 rounded-lg p-3">
            <div class="text-xs font-bold text-amber-400 mb-1">Golden Master</div>
            <p class="text-xs text-slate-300">Ejecutas el código, guardas el resultado (150), y dices: "a partir de ahora, si cambia, avísame". No necesitas saber si 150 es correcto — solo que no cambie sin querer.</p>
          </div>
        </div>
      </div>

      <div class="mb-6">
        <div class="text-sm font-bold text-white mb-3">Cómo funciona paso a paso</div>
        <div class="space-y-3">
          <div class="flex gap-3 items-start">
            <span class="shrink-0 w-7 h-7 rounded-full bg-amber-500/20 text-amber-400 text-xs font-bold flex items-center justify-center">1</span>
            <div>
              <div class="text-sm font-bold text-white">Captura</div>
              <p class="text-xs text-slate-300">Ejecutas el código legacy con un conjunto de inputs y guardas TODA la salida: respuestas HTTP, JSONs, CSVs, HTML renderizado, lo que sea. Esta salida es tu Golden Master.</p>
            </div>
          </div>
          <div class="flex gap-3 items-start">
            <span class="shrink-0 w-7 h-7 rounded-full bg-amber-500/20 text-amber-400 text-xs font-bold flex items-center justify-center">2</span>
            <div>
              <div class="text-sm font-bold text-white">Refactoriza</div>
              <p class="text-xs text-slate-300">Haces tus cambios en el código: extraes clases, renombras variables, mueves lógica a puertos. Lo que necesites.</p>
            </div>
          </div>
          <div class="flex gap-3 items-start">
            <span class="shrink-0 w-7 h-7 rounded-full bg-amber-500/20 text-amber-400 text-xs font-bold flex items-center justify-center">3</span>
            <div>
              <div class="text-sm font-bold text-white">Compara</div>
              <p class="text-xs text-slate-300">Ejecutas los mismos inputs sobre el código modificado y comparas la salida con el Golden Master. Si son iguales → no rompiste nada. Si difieren → algo cambió y tienes que investigar.</p>
            </div>
          </div>
          <div class="flex gap-3 items-start">
            <span class="shrink-0 w-7 h-7 rounded-full bg-green-500/20 text-green-400 text-xs font-bold flex items-center justify-center">4</span>
            <div>
              <div class="text-sm font-bold text-white">Itera</div>
              <p class="text-xs text-slate-300">Cuando un cambio es intencionado (bug fix, nueva feature), actualizas el Golden Master. Tu nueva "referencia dorada" refleja el comportamiento correcto actualizado.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-slate-900 border border-slate-700 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-white mb-3">Ejemplo práctico</div>
        <pre class="text-xs bg-slate-950 rounded-lg p-3 overflow-x-auto mb-3"><code class="text-green-300">// 1. Generar el Golden Master (solo una vez)
const inputs = loadTestCases('legacy_inputs.json');  // 500 casos
const results = inputs.map(i => legacyCalculatePrice(i));
writeFile('golden_master.json', JSON.stringify(results));

// 2. Test: comparar contra el master
test('no regression vs golden master', () => {
  const inputs = loadTestCases('legacy_inputs.json');
  const expected = JSON.parse(readFile('golden_master.json'));
  const actual = inputs.map(i => legacyCalculatePrice(i));
  expect(actual).toEqual(expected);  // diff exacto
});</code></pre>
        <p class="text-xs text-slate-400">Con 500 inputs y una comparación exacta, tienes una cobertura brutal sin haber entendido una sola línea del código legacy.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <div class="bg-green-950/30 border border-green-500/30 rounded-lg p-4">
          <div class="text-sm font-bold text-green-400 mb-2">Cuándo usarlo</div>
          <ul class="text-xs space-y-1.5 text-slate-300">
            <li>✓ Código legacy sin tests que necesitas refactorizar</li>
            <li>✓ Lógica de cálculo compleja que nadie entiende al 100%</li>
            <li>✓ Migración de sistema: verificar que el nuevo produce lo mismo</li>
            <li>✓ Antes de extraer dominio de un monolito</li>
            <li>✓ Generación de informes, PDFs, exports</li>
          </ul>
        </div>
        <div class="bg-red-950/30 border border-red-500/30 rounded-lg p-4">
          <div class="text-sm font-bold text-red-400 mb-2">Limitaciones</div>
          <ul class="text-xs space-y-1.5 text-slate-300">
            <li>✗ Si el código actual tiene bugs, el Golden Master los "bendice"</li>
            <li>✗ No sirve para outputs no deterministas (fechas, random, UUIDs)</li>
            <li>✗ Outputs muy grandes pueden hacer el diff lento</li>
            <li>✗ No reemplaza tests unitarios — es un puente para llegar a ellos</li>
            <li>✗ Cambios cosméticos (espacios, orden de keys) dan falsos positivos</li>
          </ul>
        </div>
      </div>

      <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-white mb-2">Herramientas</div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
          <div class="bg-slate-900 rounded p-2 text-center">
            <div class="text-xs font-mono text-amber-400">Approval Tests</div>
            <div class="text-xs text-slate-500">Java, C#, JS</div>
          </div>
          <div class="bg-slate-900 rounded p-2 text-center">
            <div class="text-xs font-mono text-amber-400">Jest Snapshots</div>
            <div class="text-xs text-slate-500">JavaScript</div>
          </div>
          <div class="bg-slate-900 rounded p-2 text-center">
            <div class="text-xs font-mono text-amber-400">TextTest</div>
            <div class="text-xs text-slate-500">Python, Java</div>
          </div>
          <div class="bg-slate-900 rounded p-2 text-center">
            <div class="text-xs font-mono text-amber-400">Verify</div>
            <div class="text-xs text-slate-500">.NET</div>
          </div>
        </div>
      </div>

      <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg p-4">
        <div class="text-sm font-bold text-amber-300 mb-2">Golden Master + Hexagonal = modernización segura</div>
        <p class="text-sm text-slate-300">El flujo ideal para atacar legacy: <strong class="text-white">1)</strong> Golden Master sobre el sistema actual → <strong class="text-white">2)</strong> Extraer dominio puro con puertos → <strong class="text-white">3)</strong> Escribir tests unitarios sobre el dominio nuevo → <strong class="text-white">4)</strong> Retirar el Golden Master cuando los tests unitarios cubran la lógica. El Golden Master es el andamio; los tests de dominio son el edificio.</p>
      </div>
    `,
  },
  {
    id: 'sindrome-impostor',
    question: '¿Qué es el síndrome del impostor en tech?',
    answer: `
      <p class="mb-4">El <strong class="text-white">síndrome del impostor</strong> es esa voz interior que te dice: <em class="text-slate-300">"en cualquier momento van a descubrir que no sé lo que hago"</em>. En tecnología es <strong class="text-white">extremadamente común</strong> — y afecta más a la gente competente que a la incompetente.</p>

      <div class="bg-slate-900 border border-slate-700 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-white mb-3">Frases que has pensado (o pensarás)</div>
        <div class="space-y-2">
          <div class="bg-slate-800/50 rounded-lg p-3 border-l-2 border-amber-400">
            <p class="text-sm text-slate-300 italic">"Todos mis compañeros saben más que yo"</p>
          </div>
          <div class="bg-slate-800/50 rounded-lg p-3 border-l-2 border-amber-400">
            <p class="text-sm text-slate-300 italic">"Si me han contratado es porque no se han dado cuenta de que no sé suficiente"</p>
          </div>
          <div class="bg-slate-800/50 rounded-lg p-3 border-l-2 border-amber-400">
            <p class="text-sm text-slate-300 italic">"No debería tardar tanto en entender esto"</p>
          </div>
          <div class="bg-slate-800/50 rounded-lg p-3 border-l-2 border-amber-400">
            <p class="text-sm text-slate-300 italic">"Cuando me pregunten en la daily, van a ver que no he avanzado nada"</p>
          </div>
          <div class="bg-slate-800/50 rounded-lg p-3 border-l-2 border-amber-400">
            <p class="text-sm text-slate-300 italic">"Ese junior hace PRs más limpias que las mías"</p>
          </div>
        </div>
      </div>

      <div class="mb-6">
        <div class="text-sm font-bold text-white mb-3">Por qué es tan común en software</div>
        <div class="grid md:grid-cols-2 gap-3">
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-purple-400 mb-1">El campo es infinito</div>
            <p class="text-xs text-slate-400">Nadie sabe todo. Ni el senior con 20 años. Frontend, backend, DevOps, IA, seguridad, redes, bases de datos, cloud... Es literalmente imposible dominarlo todo. Siempre habrá alguien que sepa más que tú en algo.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-purple-400 mb-1">La tecnología cambia cada semana</div>
            <p class="text-xs text-slate-400">El framework que aprendiste hace 2 años ya tiene sucesor. La sensación de "ir siempre por detrás" es estructural al sector, no un fallo tuyo.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-purple-400 mb-1">Solo ves tu código por dentro</div>
            <p class="text-xs text-slate-400">Ves todos tus bugs, tus dudas, tus momentos de "no sé por dónde empezar". De los demás solo ves el resultado final: el PR limpio, la charla brillante, el artículo publicado. No ves sus 47 intentos fallidos.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-3">
            <div class="text-xs font-bold text-purple-400 mb-1">La cultura del "10x developer"</div>
            <p class="text-xs text-slate-400">Twitter/X y LinkedIn están llenos de gente que aparenta saber todo. Es un sesgo de supervivencia: los que dudan no publican, los que presumen sí. La realidad es mucho más humilde.</p>
          </div>
        </div>
      </div>

      <div class="bg-slate-900 border border-slate-700 rounded-lg p-4 mb-6">
        <div class="text-sm font-bold text-white mb-3">Dato: a quién afecta más</div>
        <div class="grid md:grid-cols-3 gap-3">
          <div class="bg-green-950/30 border border-green-500/30 rounded-lg p-3 text-center">
            <div class="text-2xl font-bold text-green-400">70%</div>
            <p class="text-xs text-slate-400">de las personas lo experimentan al menos una vez en su carrera</p>
          </div>
          <div class="bg-blue-950/30 border border-blue-500/30 rounded-lg p-3 text-center">
            <div class="text-2xl font-bold text-blue-400">Seniors</div>
            <p class="text-xs text-slate-400">lo sufren MÁS que juniors — cuanto más sabes, más ves lo que no sabes</p>
          </div>
          <div class="bg-amber-950/30 border border-amber-500/30 rounded-lg p-3 text-center">
            <div class="text-2xl font-bold text-amber-400">Mujeres</div>
            <p class="text-xs text-slate-400">y minorías en tech lo sufren con más intensidad por la presión de "demostrar que perteneces"</p>
          </div>
        </div>
      </div>

      <div class="mb-6">
        <div class="text-sm font-bold text-white mb-3">Qué ayuda (de verdad)</div>
        <div class="space-y-3">
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-green-400 mb-1">1. Normaliza no saber</div>
            <p class="text-xs text-slate-300">Decir "no sé" no es debilidad, es honestidad. Los mejores seniors que conozco dicen "no sé, pero lo averiguo" varias veces al día. Lo peligroso es el que nunca lo dice.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-green-400 mb-1">2. Lleva un "diario de logros"</div>
            <p class="text-xs text-slate-300">Apunta cada semana algo que conseguiste: un bug resuelto, algo que aprendiste, una PR que mergeaste. Cuando te venga el impostor, relee la lista. Los hechos no mienten.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-green-400 mb-1">3. Compárate contigo de hace 6 meses</div>
            <p class="text-xs text-slate-300">No con el senior que lleva 15 años. No con el influencer de Twitter. Contigo mismo hace medio año. Si sabes algo que entonces no sabías, estás avanzando. Eso es lo único que importa.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-green-400 mb-1">4. Habla de ello</div>
            <p class="text-xs text-slate-300">Con un compañero, un mentor, o tu padre. Cuando lo dices en voz alta, descubres que la otra persona siente exactamente lo mismo. El impostor pierde fuerza cuando deja de ser un secreto.</p>
          </div>
          <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div class="text-sm font-bold text-green-400 mb-1">5. Enseña lo que sabes</div>
            <p class="text-xs text-slate-300">Explicar algo a alguien te obliga a darte cuenta de cuánto sabes realmente. Un junior que explica Git a otro junior descubre que sabe más de lo que creía. Esta web existe por eso.</p>
          </div>
        </div>
      </div>

      <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg p-4">
        <div class="text-sm font-bold text-amber-300 mb-2">Lo que tu padre quiere que sepas</div>
        <p class="text-sm text-slate-300">Después de más de 35 años escribiendo software, te confirmo: <strong class="text-white">yo también me siento impostor a veces</strong>. La diferencia es que ahora sé que es normal, que le pasa a todo el mundo, y que no significa que no seas bueno. Significa que te importa hacerlo bien. Y eso, hijo, es exactamente lo que necesita un buen ingeniero.</p>
      </div>
    `,
  },
];
---

<section id="faq" class="max-w-5xl mx-auto px-6 py-24 reveal">
  <div class="text-center mb-16">
    <span class="text-xs font-mono text-sky-400 uppercase tracking-widest">Formación</span>
    <h2 class="text-3xl font-bold text-white mt-3 mb-2">Conceptos y FAQ</h2>
    <p class="text-slate-400 max-w-2xl mx-auto">
      Preguntas frecuentes y conceptos clave que aparecen cuando trabajas con
      arquitectura de software. Explicados con ejemplos, no con definiciones de libro.
    </p>
  </div>

  <div class="space-y-4" id="faq-list">
    {faqs.map(faq => (
      <div class="border border-slate-700 rounded-xl overflow-hidden" id={faq.id} data-faq={faq.id}>
        <button
          class="faq-toggle w-full flex items-center justify-between px-6 py-5 bg-slate-800/50 hover:bg-slate-800 transition-colors text-left"
          aria-expanded="false"
        >
          <span class="text-lg font-semibold text-white pr-4">{faq.question}</span>
          <svg class="faq-chevron w-5 h-5 text-slate-400 shrink-0 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="faq-content hidden px-6 py-6 bg-slate-900/50">
          <div class="prose-sm" set:html={faq.answer} />
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  document.getElementById('faq-list')?.addEventListener('click', function(e) {
    var btn = (e.target as HTMLElement).closest('.faq-toggle');
    if (!btn) return;
    var content = btn.nextElementSibling as HTMLElement;
    var chevron = btn.querySelector('.faq-chevron') as HTMLElement;
    var expanded = btn.getAttribute('aria-expanded') === 'true';

    // Close all others
    document.querySelectorAll('.faq-toggle').forEach(function(other) {
      if (other !== btn) {
        other.setAttribute('aria-expanded', 'false');
        (other.nextElementSibling as HTMLElement)?.classList.add('hidden');
        (other.querySelector('.faq-chevron') as HTMLElement)?.classList.remove('rotate-180');
      }
    });

    // Toggle current
    btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    content?.classList.toggle('hidden');
    chevron?.classList.toggle('rotate-180');
  });

  // Deep link: open FAQ from URL hash
  function openFromHash() {
    var hash = window.location.hash.replace('#', '');
    if (!hash) return;
    var target = document.querySelector('[data-faq="' + hash + '"]') as HTMLElement;
    if (!target) return;
    var btn = target.querySelector('.faq-toggle') as HTMLElement;
    if (btn && btn.getAttribute('aria-expanded') !== 'true') {
      btn.click();
    }
    setTimeout(function() { target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 100);
  }
  openFromHash();
  window.addEventListener('hashchange', openFromHash);
</script>
