---
// Request Flow Visualizer
const steps = [
  {
    num: 1, layer: 'infra', label: 'Infraestructura',
    title: 'HTTP Request llega al adaptador',
    desc: 'Express recibe POST /api/orders. OrderController parsea el body y construye un',
    code: 'CreateOrderCommand',
    layerBadge: 'Infraestructura',
  },
  {
    num: 2, layer: 'infra', label: 'Infraestructura',
    title: 'El adaptador llama al puerto de entrada',
    desc: 'OrderController llama a',
    code: 'createOrderUseCase.execute(command)',
    desc2: '. Solo conoce la interfaz, no la implementacion.',
    layerBadge: 'Infraestructura → Aplicacion',
  },
  {
    num: 3, layer: 'app', label: 'Aplicacion',
    title: 'Use Case orquesta el flujo',
    desc: 'CreateOrderService recibe el command. Delega la creacion al dominio con',
    code: 'Order.create(...)',
    layerBadge: 'Aplicacion',
  },
  {
    num: 4, layer: 'domain', label: 'Dominio',
    title: 'El dominio ejecuta la logica de negocio',
    desc: 'Order.create valida: debe haber items, cantidades positivas, etc. Si algo falla, lanza un error. Si no, crea la entidad.',
    code: '',
    layerBadge: 'Dominio',
  },
  {
    num: 5, layer: 'app', label: 'Aplicacion',
    title: 'El Use Case persiste y notifica',
    desc: 'Llama a',
    code: 'orderRepository.save(order)',
    desc2: ' y luego a notificationPort. Ambos son puertos — no sabe quien los implementa.',
    layerBadge: 'Aplicacion',
  },
  {
    num: 6, layer: 'infra', label: 'Infraestructura',
    title: 'Los adaptadores de salida actuan',
    desc: 'InMemoryOrderRepository guarda el pedido. ConsoleNotificationAdapter imprime el log.',
    code: '',
    layerBadge: 'Infraestructura',
  },
  {
    num: 7, layer: 'infra', label: 'Infraestructura',
    title: 'El adaptador devuelve la respuesta HTTP',
    desc: 'OrderController recibe la Order y devuelve',
    code: 'res.status(201).json(order)',
    desc2: '. El dominio nunca supo que habia un HTTP de por medio.',
    layerBadge: 'Infraestructura',
  },
];

const layerColors: Record<string, string> = {
  infra: 'purple',
  app: 'blue',
  domain: 'amber',
};
---

<section id="flujo" class="max-w-5xl mx-auto px-6 py-24 reveal">
  <h2 class="text-3xl font-extrabold mb-2 tracking-tight">Flujo de una Peticion</h2>
  <p class="text-slate-400 mb-10 text-lg">Sigue el recorrido de POST /api/orders a traves de todas las capas.</p>

  <div class="bg-slate-800/40 border border-slate-700 rounded-xl p-6 md:p-8">

    <!-- Steps -->
    <div class="space-y-3 mb-8" id="flow-steps">
      {steps.map((s, i) => {
        const color = layerColors[s.layer];
        const borderActive  = color === 'amber'  ? 'border-amber-400'  : color === 'blue' ? 'border-blue-400'  : 'border-purple-400';
        const bgActive      = color === 'amber'  ? 'bg-amber-400/8'    : color === 'blue' ? 'bg-blue-400/8'    : 'bg-purple-400/8';
        const numBg         = color === 'amber'  ? 'bg-amber-400 text-black' : color === 'blue' ? 'bg-blue-500 text-white' : 'bg-purple-500 text-white';
        const badgeBg       = color === 'amber'  ? 'bg-amber-100 text-amber-900' : color === 'blue' ? 'bg-blue-100 text-blue-900' : 'bg-purple-100 text-purple-900';

        return (
          <div
            class={`flow-step flex items-start gap-4 p-4 rounded-lg border border-slate-700 bg-slate-900
                    opacity-30 translate-x-[-6px]
                    data-[active=true]:opacity-100 data-[active=true]:translate-x-0 data-[active=true]:${borderActive} data-[active=true]:${bgActive}
                    data-[done=true]:opacity-60 data-[done=true]:translate-x-0`}
            data-step={i}
            data-layer={s.layer}
            data-border={borderActive}
            data-bg={bgActive}
            data-num-bg={numBg}
          >
            <div class={`flow-num w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0 mt-0.5 bg-slate-700 text-slate-400`}
                 data-num={i}>
              {s.num}
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-sm text-slate-200 mb-1">{s.title}</div>
              <p class="text-slate-400 text-xs leading-relaxed">
                {s.desc}{s.code && <code class="bg-slate-800 px-1.5 py-0.5 rounded font-mono text-amber-300">{s.code}</code>}{s.desc2 || ''}
              </p>
            </div>
            <span class={`text-xs font-bold px-2 py-1 rounded-full shrink-0 ${badgeBg}`}>
              {s.layerBadge}
            </span>
          </div>
        );
      })}
    </div>

    <!-- Controls -->
    <div class="flex items-center gap-4">
      <button id="flow-prev" class="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-sm font-semibold transition-colors disabled:opacity-30" disabled>
        Anterior
      </button>
      <div class="flex-1 h-1 bg-slate-700 rounded-full overflow-hidden">
        <div id="flow-bar" class="h-full bg-amber-400 rounded-full transition-all duration-400" style="width:0%"></div>
      </div>
      <button id="flow-next" class="px-4 py-2 rounded-lg bg-amber-400 hover:bg-amber-300 text-black text-sm font-semibold transition-colors">
        Siguiente
      </button>
      <button id="flow-reset" class="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-sm font-semibold transition-colors">
        Reiniciar
      </button>
    </div>

    <!-- Step counter -->
    <p class="text-center text-slate-500 text-xs mt-4">
      Paso <span id="flow-current">0</span> de {steps.length}
    </p>
  </div>
</section>

<script>
  const totalSteps = 7;
  let current = 0;

  const stepEls  = document.querySelectorAll('.flow-step');
  const bar      = document.getElementById('flow-bar');
  const counter  = document.getElementById('flow-current');
  const btnNext  = document.getElementById('flow-next');
  const btnPrev  = document.getElementById('flow-prev');
  const btnReset = document.getElementById('flow-reset');

  function render() {
    stepEls.forEach((el, i) => {
      el.removeAttribute('data-active');
      el.removeAttribute('data-done');

      const numEl   = el.querySelector('[data-num]');
      const borderC = el.dataset.border || '';
      const numBg   = el.dataset.numBg  || '';

      if (i === current - 1) {
        el.dataset.active = 'true';
        el.classList.remove('opacity-30');
        el.classList.add('opacity-100', 'translate-x-0');
        el.style.borderColor = borderC.includes('amber') ? '#f59e0b'
          : borderC.includes('blue') ? '#3b82f6' : '#8b5cf6';
        if (numEl) {
          numEl.style.background = numBg.includes('amber') ? '#f59e0b'
            : numBg.includes('blue') ? '#3b82f6' : '#8b5cf6';
          numEl.style.color = numBg.includes('amber') ? '#000' : '#fff';
        }
      } else if (i < current - 1) {
        el.dataset.done = 'true';
        el.classList.remove('opacity-30');
        el.classList.add('opacity-60', 'translate-x-0');
      } else {
        el.classList.add('opacity-30');
        el.classList.remove('opacity-60', 'opacity-100', 'translate-x-0');
        el.style.borderColor = '';
        if (numEl) { numEl.style.background = ''; numEl.style.color = ''; }
      }
    });

    bar.style.width = `${(current / totalSteps) * 100}%`;
    counter.textContent = String(current);
    btnPrev.disabled = current === 0;
    btnNext.disabled = current === totalSteps;
  }

  btnNext.addEventListener('click',  () => { if (current < totalSteps) { current++; render(); }});
  btnPrev.addEventListener('click',  () => { if (current > 0) { current--; render(); }});
  btnReset.addEventListener('click', () => { current = 0; render(); });

  render();
</script>
