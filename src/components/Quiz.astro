const questions = [
  // ── FUNDAMENTOS ────────────────────────────────────────────────
  {
    topic: 'Fundamentos', difficulty: 'easy',
    q: 'En arquitectura hexagonal, la regla de dependencia dice que...',
    options: [
      'Las capas externas dependen de las internas',
      'Las capas internas dependen de las externas',
      'Todas las capas son independientes entre si',
      'El dominio puede importar Express si es necesario',
    ],
    correct: 0,
    explanation: 'Las capas externas (infraestructura) dependen de las internas (dominio). Nunca al revés. El dominio no conoce Express, Prisma ni ningún framework externo.',
  },
  {
    topic: 'Fundamentos', difficulty: 'easy',
    q: 'Cuál es el nombre original de la arquitectura hexagonal?',
    options: [
      'Clean Architecture',
      'Ports & Adapters',
      'Onion Architecture',
      'Layered Architecture',
    ],
    correct: 1,
    explanation: 'Alistair Cockburn la llamo "Ports & Adapters" en 2005. El hexágono es solo la representación visual. El nombre describe exactamente como funciona: puertos (interfaces) y adaptadores (implementaciones).',
  },
