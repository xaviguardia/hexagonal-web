---
const inputCodeHtml = [
  '<span class="token-cm">// src/domain/ports/input.ports.ts</span>',
  '<span class="token-kw">export interface</span> <span class="token-tp">CreateOrderUseCase</span> {',
  '  <span class="token-fn">execute</span>(cmd<span class="token-op">:</span> <span class="token-tp">CreateOrderCommand</span>)<span class="token-op">:</span> <span class="token-tp">Promise</span>&lt;<span class="token-tp">Order</span>&gt;;',
  '}',
].join('\n');

const outputCodeHtml = [
  '<span class="token-cm">// src/domain/ports/output.ports.ts</span>',
  '<span class="token-kw">export interface</span> <span class="token-tp">OrderRepository</span> {',
  '  <span class="token-fn">save</span>(order<span class="token-op">:</span> <span class="token-tp">Order</span>)<span class="token-op">:</span> <span class="token-tp">Promise</span>&lt;<span class="token-kw">void</span>&gt;;',
  '  <span class="token-fn">findById</span>(id<span class="token-op">:</span> <span class="token-tp">string</span>)<span class="token-op">:</span> <span class="token-tp">Promise</span>&lt;<span class="token-tp">Order</span> | <span class="token-kw">null</span>&gt;;',
  '}',
].join('\n');

const drivingAdapters = [
  { name: 'OrderController', sub: 'HTTP / Express' },
  { name: 'OrderCLI',        sub: 'Línea de comandos' },
  { name: 'OrderTest',       sub: 'Tests unitarios' },
];
const drivenAdapters = [
  { name: 'PostgresOrderRepo',    sub: 'Base de datos SQL' },
  { name: 'SendGridNotification', sub: 'Email / notificaciones' },
  { name: 'InMemoryOrderRepo',    sub: 'Tests / desarrollo' },
];
---
<section id="puertos" class="max-w-5xl mx-auto px-6 py-24 reveal">
  <h2 class="text-3xl font-extrabold mb-2 tracking-tight">Puertos y Adaptadores</h2>
  <p class="text-slate-400 mb-12 text-lg">Los puertos son contratos (interfaces). Los adaptadores son implementaciones concretas.</p>

  <!-- Diagram -->
  <div class="bg-slate-800/40 border border-slate-700 rounded-xl p-8 mb-12">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-6 items-center">

      <!-- Driving side -->
      <div class="space-y-3">
        <p class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-4">Adaptadores de Entrada (Driving)</p>
        {drivingAdapters.map(a => (
          <div class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-sm">
            <div class="font-semibold text-slate-200">{a.name}</div>
            <div class="text-xs text-slate-500 mt-0.5">{a.sub}</div>
          </div>
        ))}
        <p class="text-xs text-slate-500 pt-1">Invocan los puertos de entrada</p>
      </div>

      <!-- Center: Domain + ports -->
      <div class="flex flex-col items-center gap-3">
        <div class="text-xs text-blue-400 font-semibold tracking-wider">PUERTO ENTRADA</div>
        <div class="w-px h-6 bg-blue-500/50"></div>
        <div class="bg-amber-400/10 border-2 border-amber-400 rounded-xl px-6 py-5 text-center min-w-[150px]">
          <div class="text-amber-400 font-bold text-sm mb-1">DOMINIO</div>
          <div class="text-xs text-amber-400/70">Lógica de negocio</div>
          <div class="text-xs text-amber-400/70 mt-1">Order, OrderItem...</div>
        </div>
        <div class="w-px h-6 bg-purple-500/50"></div>
        <div class="text-xs text-purple-400 font-semibold tracking-wider">PUERTO SALIDA</div>
      </div>

      <!-- Driven side -->
      <div class="space-y-3">
        <p class="text-xs font-bold uppercase tracking-widest text-purple-400 mb-4">Adaptadores de Salida (Driven)</p>
        {drivenAdapters.map(a => (
          <div class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-sm">
            <div class="font-semibold text-slate-200">{a.name}</div>
            <div class="text-xs text-slate-500 mt-0.5">{a.sub}</div>
          </div>
        ))}
        <p class="text-xs text-slate-500 pt-1">Implementan los puertos de salida</p>
      </div>
    </div>
  </div>

  <!-- Port types explained -->
  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-slate-800/40 border border-blue-500/30 rounded-xl p-6">
      <div class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-3">Puerto de Entrada</div>
      <p class="text-slate-300 text-sm mb-3">Interfaz que expone el dominio. Define lo que el sistema puede hacer.</p>
      <pre class="bg-slate-900 rounded-lg p-4 text-xs overflow-x-auto"><code set:html={inputCodeHtml} /></pre>
    </div>
    <div class="bg-slate-800/40 border border-purple-500/30 rounded-xl p-6">
      <div class="text-xs font-bold uppercase tracking-widest text-purple-400 mb-3">Puerto de Salida</div>
      <p class="text-slate-300 text-sm mb-3">Interfaz que el dominio necesita. Lo define el dominio, lo implementa la infra.</p>
      <pre class="bg-slate-900 rounded-lg p-4 text-xs overflow-x-auto"><code set:html={outputCodeHtml} /></pre>
    </div>
  </div>
</section>
