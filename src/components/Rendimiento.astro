---
const kw = (s) => `<span class="text-purple-400">${s}</span>`;
const fn = (s) => `<span class="text-yellow-300">${s}</span>`;
const tp = (s) => `<span class="text-cyan-300">${s}</span>`;
const cm = (s) => `<span class="text-slate-500">${s}</span>`;
const st = (s) => `<span class="text-emerald-300">${s}</span>`;
const nm = (s) => `<span class="text-slate-200">${s}</span>`;
const er = (s) => `<span class="text-red-400">${s}</span>`;
const ok = (s) => `<span class="text-green-400">${s}</span>`;
const w = (s) => `<span class="text-amber-300">${s}</span>`;

const patterns = [
  {
    id: 'read-model',
    title: 'Read Model / CQRS',
    badge: 'Consultas costosas',
    description: 'Las consultas de lectura no necesitan pasar por el agregado completo. Crear un modelo de lectura plano elimina el coste de reconstruir entidades ricas para solo mostrar datos.',
    problem: [
      er('// PROBLEMA: reconstruir Order completa solo para listar'),
      cm('// OrderRepository carga Order con todos sus Value Objects'),
      cm('// solo para devolver { id, customerId, total, status }'),
      '',
      `${kw('class')} ${tp('GetOrdersService')} {`,
      `  ${kw('async')} ${fn('execute')}(${nm('customerId')}: ${tp('string')}) {`,
      `    ${kw('const')} ${nm('orders')} = ${kw('await')} ${kw('this')}.${nm('repo')}.${fn('findByCustomer')}(${nm('customerId')});`,
      er('    // Carga entidad completa: Items[], Address, PaymentInfo...'),
      er('    // Solo para proyectar 3 campos al frontend'),
      `    ${kw('return')} ${nm('orders')}.${fn('map')}(${nm('o')} => ({`,
      `      id: ${nm('o')}.id, total: ${nm('o')}.total, status: ${nm('o')}.status`,
      `    }));`,
      `  }`,
      `}`,
    ].join('\n'),
    solution: [
      ok('// SOLUCION: Read Model — proyección plana, sin agregado'),
      '',
      cm('// domain/ports/output.ports.ts — puerto de lectura separado'),
      `${kw('interface')} ${tp('OrderReadModel')} {`,
      `  id: ${tp('string')}; customerId: ${tp('string')};`,
      `  total: ${tp('number')}; status: ${tp('string')}; createdAt: ${tp('Date')};`,
      `}`,
      '',
      `${kw('interface')} ${tp('OrderQueryRepository')} {`,
      cm('  // Solo devuelve lo que necesita la vista'),
      `  ${fn('findSummaryByCustomer')}(${nm('id')}: ${tp('string')}): ${tp('Promise<OrderReadModel[]>')};`,
      `}`,
      '',
      cm('// infrastructure: query SQL directa, sin ORM complejo'),
      `${kw('class')} ${tp('PgOrderQueryRepository')} ${kw('implements')} ${tp('OrderQueryRepository')} {`,
      `  ${kw('async')} ${fn('findSummaryByCustomer')}(${nm('id')}: ${tp('string')}) {`,
      `    ${kw('return')} ${kw('this')}.${nm('db')}.${fn('query')}(`,
      `      ${st('`SELECT id, total, status FROM orders WHERE customer_id=$1`')},`,
      `      [${nm('id')}]`,
      `    );`,
      `  }`,
      `}`,
    ].join('\n'),
    insight: 'El dominio sigue intacto para escrituras. Las lecturas usan una proyección optimizada. El puerto de salida hace de frontera: el dominio nunca sabe si la consulta va a PostgreSQL, Redis o Elasticsearch.',
  },
  {
    id: 'cache',
    title: 'Cache en Capa de Aplicación',
    badge: 'N llamadas repetidas',
    description: 'El cache no contamina el dominio. Se implementa como un adaptador que decora el repositorio original, respetando el puerto definido.',
    problem: [
      er('// PROBLEMA: GetOrderService llama al repo en cada request'),
      cm('// Misma orden leida 100 veces por segundo en producción'),
      '',
      `${kw('class')} ${tp('GetOrderService')} {`,
      `  ${kw('async')} ${fn('execute')}(${nm('orderId')}: ${tp('string')}) {`,
      er('    // Siempre va a base de datos, sin cache'),
      `    ${kw('const')} ${nm('order')} = ${kw('await')} ${kw('this')}.${nm('repo')}.${fn('findById')}(${nm('orderId')});`,
      `    ${kw('if')} (!${nm('order')}) ${kw('throw new')} ${tp('Error')}(${st('`Not found`')});`,
      `    ${kw('return')} ${nm('order')};`,
      `  }`,
      `}`,
      '',
      er('// El dominio NO debe saber que existe Redis'),
      er('// Meter cache aquí violaría la regla de dependencia'),
    ].join('\n'),
    solution: [
      ok('// SOLUCION: Adaptador decorador — el puerto no cambia'),
      '',
      cm('// infrastructure/driven/CachedOrderRepository.ts'),
      `${kw('class')} ${tp('CachedOrderRepository')} ${kw('implements')} ${tp('OrderRepository')} {`,
      `  ${kw('constructor')}(`,
      `    ${kw('private')} ${nm('inner')}: ${tp('OrderRepository')},`,
      `    ${kw('private')} ${nm('cache')}: ${tp('CachePort')}`,
      `  ) {}`,
      '',
      `  ${kw('async')} ${fn('findById')}(${nm('id')}: ${tp('string')}) {`,
      `    ${kw('const')} ${nm('hit')} = ${kw('await')} ${kw('this')}.${nm('cache')}.${fn('get')}(${nm('id')});`,
      `    ${kw('if')} (${nm('hit')}) ${kw('return')} ${tp('JSON')}.${fn('parse')}(${nm('hit')});`,
      '',
      `    ${kw('const')} ${nm('order')} = ${kw('await')} ${kw('this')}.${nm('inner')}.${fn('findById')}(${nm('id')});`,
      `    ${kw('if')} (${nm('order')}) ${kw('await')} ${kw('this')}.${nm('cache')}.${fn('set')}(${nm('id')}, ${tp('JSON')}.${fn('stringify')}(${nm('order')}), 60);`,
      `    ${kw('return')} ${nm('order')};`,
      `  }`,
      `}`,
      '',
      cm('// main.ts — se inyecta transparentemente'),
      `${kw('const')} ${nm('repo')} = ${kw('new')} ${tp('CachedOrderRepository')}(`,
      `  ${kw('new')} ${tp('PgOrderRepository')}(${nm('db')}),`,
      `  ${kw('new')} ${tp('RedisCache')}(${nm('redis')})`,
      `);`,
    ].join('\n'),
    insight: 'GetOrderService no cambió ni una línea. El dominio no sabe que existe Redis. El Decorator Pattern aplicado al puerto de salida es la forma hexagonal de hacer cache.',
  },
  {
    id: 'n-plus-one',
    title: 'Problema N+1',
    badge: 'Bucles de consultas',
    description: 'Cada entidad del dominio lanzando una query individual dentro de un bucle. El repositorio resuelve esto con una query batch sin que el dominio lo sepa.',
    problem: [
      er('// PROBLEMA: N+1 queries'),
      cm('// Listar 50 órdenes y para cada una cargar el cliente'),
      '',
      `${kw('class')} ${tp('ListOrdersService')} {`,
      `  ${kw('async')} ${fn('execute')}() {`,
      `    ${kw('const')} ${nm('orders')} = ${kw('await')} ${kw('this')}.${nm('orderRepo')}.${fn('findAll')}();`,
      er('    // 50 órdenes = 50 queries al repo de clientes'),
      `    ${kw('for')} (${kw('const')} ${nm('order')} ${kw('of')} ${nm('orders')}) {`,
      `      ${nm('order')}.customer = ${kw('await')} ${kw('this')}.${nm('customerRepo')}.${fn('findById')}(${nm('order')}.customerId);`,
      `    }`,
      `    ${kw('return')} ${nm('orders')};`,
      `  }`,
      `}`,
    ].join('\n'),
    solution: [
      ok('// SOLUCION: batch query en el repositorio'),
      cm('// El dominio no cambia — solo el adaptador'),
      '',
      cm('// domain/ports/output.ports.ts'),
      `${kw('interface')} ${tp('CustomerRepository')} {`,
      `  ${fn('findById')}(${nm('id')}: ${tp('string')}): ${tp('Promise<Customer | null>')};`,
      ok(`  ${fn('findByIds')}(${nm('ids')}: ${tp('string[]')}): ${tp('Promise<Map<string, Customer>>')};`),
      `}`,
      '',
      cm('// application service — 2 queries en vez de N+1'),
      `${kw('async')} ${fn('execute')}() {`,
      `  ${kw('const')} ${nm('orders')} = ${kw('await')} ${kw('this')}.${nm('orderRepo')}.${fn('findAll')}();`,
      `  ${kw('const')} ${nm('ids')} = ${nm('orders')}.${fn('map')}(${nm('o')} => ${nm('o')}.customerId);`,
      ok(`  ${kw('const')} ${nm('customers')} = ${kw('await')} ${kw('this')}.${nm('customerRepo')}.${fn('findByIds')}(${nm('ids')});`),
      `  ${kw('return')} ${nm('orders')}.${fn('map')}(${nm('o')} => ({`,
      `    ...${nm('o')}, customer: ${nm('customers')}.${fn('get')}(${nm('o')}.customerId)`,
      `  }));`,
      `}`,
      '',
      cm('// PgCustomerRepository implementa findByIds con WHERE id IN (...)'),
    ].join('\n'),
    insight: 'El puerto define "que" se puede pedir, el adaptador decide "como" hacerlo eficientemente. Añadir findByIds al puerto no contamina el dominio, solo expande el contrato.',
  },
];
---

<section id="rendimiento" class="py-24 px-6 max-w-6xl mx-auto reveal">
  <div class="text-center mb-16">
    <span class="text-xs font-mono text-cyan-400 uppercase tracking-widest">Rendimiento</span>
    <h2 class="text-3xl font-bold text-white mt-3 mb-4">Optimizar sin contaminar el dominio</h2>
    <p class="text-slate-400 max-w-2xl mx-auto">
      El error típico es meter cache, queries directas o lógica de optimización dentro del dominio.
      La arquitectura hexagonal tiene un lugar exacto para cada optimización.
    </p>
  </div>

  <!-- Tabs -->
  <div class="flex flex-wrap gap-3 justify-center mb-12">
    {patterns.map((p, i) => (
      <button
        class="perf-tab px-4 py-2 rounded-lg text-sm font-mono border transition-all"
        data-tab={p.id}
        class:list={[
          i === 0
            ? 'bg-cyan-500/20 border-cyan-500/50 text-cyan-300'
            : 'bg-slate-800 border-slate-700 text-slate-400 hover:border-slate-500'
        ]}
      >
        {p.title}
      </button>
    ))}
  </div>

  {patterns.map((p, i) => (
    <div class="perf-panel" data-panel={p.id} style={i !== 0 ? 'display:none' : ''}>
      <div class="mb-6">
        <div class="flex items-center gap-3 flex-wrap">
          <h3 class="text-white font-bold text-lg">{p.title}</h3>
          <span class="text-xs px-2 py-1 rounded-full bg-red-500/20 border border-red-500/40 text-red-300 font-mono">{p.badge}</span>
        </div>
        <p class="text-slate-400 mt-2 text-sm leading-relaxed max-w-3xl">{p.description}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-red-500"></span>
            <span class="text-red-400 text-sm font-semibold uppercase tracking-wide">Sin optimizar</span>
          </div>
          <div class="bg-slate-950 rounded-xl border border-red-900/40 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2 bg-slate-900 border-b border-red-900/40">
              <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/40"></span>
              <span class="text-slate-500 text-xs font-mono ml-2">problema</span>
            </div>
            <pre class="p-4 text-sm font-mono leading-relaxed overflow-x-auto"><code set:html={p.problem} /></pre>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-cyan-500"></span>
            <span class="text-cyan-400 text-sm font-semibold uppercase tracking-wide">Solución hexagonal</span>
          </div>
          <div class="bg-slate-950 rounded-xl border border-cyan-900/40 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2 bg-slate-900 border-b border-cyan-900/40">
              <span class="w-3 h-3 rounded-full bg-red-500/40"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/40"></span>
              <span class="w-3 h-3 rounded-full bg-cyan-500/70"></span>
              <span class="text-slate-500 text-xs font-mono ml-2">optimizado</span>
            </div>
            <pre class="p-4 text-sm font-mono leading-relaxed overflow-x-auto"><code set:html={p.solution} /></pre>
          </div>
        </div>
      </div>

      <div class="mt-6 bg-cyan-500/10 border border-cyan-500/30 rounded-xl p-5">
        <p class="text-cyan-200 text-sm leading-relaxed">
          <span class="font-semibold text-cyan-400">Clave: </span>{p.insight}
        </p>
      </div>
    </div>
  ))}
</section>

<script>
  var tabs = document.querySelectorAll('.perf-tab');
  var panels = document.querySelectorAll('.perf-panel');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.getAttribute('data-tab');
      tabs.forEach(function(t) {
        t.className = 'perf-tab px-4 py-2 rounded-lg text-sm font-mono border transition-all bg-slate-800 border-slate-700 text-slate-400 hover:border-slate-500';
      });
      tab.className = 'perf-tab px-4 py-2 rounded-lg text-sm font-mono border transition-all bg-cyan-500/20 border-cyan-500/50 text-cyan-300';
      panels.forEach(function(p) {
        p.style.display = p.getAttribute('data-panel') === target ? '' : 'none';
      });
    });
  });
</script>
