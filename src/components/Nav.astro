---
const groups = [
  {
    label: 'Fundamentos',
    links: [
      { href: '#concepto',    label: 'Concepto' },
      { href: '#capas',       label: 'Capas' },
      { href: '#puertos',     label: 'Puertos' },
      { href: '#flujo',       label: 'Flujo' },
    ]
  },
  {
    label: 'Por capa',
    links: [
      { href: '#dominio',         label: 'Dominio' },
      { href: '#usecases',        label: 'Aplicacion' },
      { href: '#infraestructura', label: 'Infraestructura' },
    ]
  },
  {
    label: 'Patrones',
    links: [
      { href: '#refactoring',       label: 'Refactoring' },
      { href: '#rendimiento',       label: 'Rendimiento' },
      { href: '#transaccionalidad', label: 'Transacciones' },
      { href: '#testing',           label: 'Testing' },
    ]
  },
  {
    label: 'Avanzado',
    links: [
      { href: '#observabilidad',      label: 'Observabilidad (OTEL)' },
      { href: '#frontend-hexagonal', label: 'Frontend Hexagonal' },
      { href: '#bpmn',               label: 'BPMN' },
      { href: '#datalake',           label: 'Data Lake' },
    ]
  },
  {
    label: 'Referencia',
    links: [
      { href: '#codigo',     label: 'Explorador de codigo' },
      { href: '#flashcards', label: 'Flashcards' },
      { href: '#quiz',       label: 'Quiz' },
    ]
  },
];

const allLinks = groups.flatMap(g => g.links);
---

<!-- Mobile top bar -->
<div class="lg:hidden fixed top-0 left-0 right-0 h-12 bg-slate-900/95 border-b border-slate-800 flex items-center px-4 z-50 backdrop-blur">
  <button id="sidebar-toggle" class="text-slate-400 hover:text-white mr-3 p-1" aria-label="Menu">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
    </svg>
  </button>
  <span class="font-bold text-amber-400 text-sm tracking-tight">Hexagonal</span>
</div>

<!-- Overlay -->
<div id="sidebar-overlay" class="lg:hidden fixed inset-0 bg-black/60 z-40 hidden"></div>

<!-- Sidebar -->
<aside id="sidebar" class="fixed top-0 left-0 h-screen w-56 bg-slate-900 border-r border-slate-800 overflow-y-auto z-50 flex flex-col
  -translate-x-full lg:translate-x-0 transition-transform duration-200">

  <div class="p-5 border-b border-slate-800 shrink-0">
    <div class="font-bold text-amber-400 text-sm tracking-tight">Hexagonal</div>
    <div class="text-xs text-slate-600 mt-0.5">Ports &amp; Adapters</div>
  </div>

  <nav class="flex-1 py-3 overflow-y-auto">
    {groups.map(group => (
      <div class="mb-4 px-3">
        <div class="text-xs font-semibold text-slate-600 uppercase tracking-widest mb-1 px-2">{group.label}</div>
        {group.links.map(link => (
          <a
            href={link.href}
            class="nav-link block px-2 py-1.5 text-sm text-slate-400 hover:text-white rounded transition-colors hover:bg-slate-800"
            data-section={link.href.replace('#', '')}
          >
            {link.label}
          </a>
        ))}
      </div>
    ))}
  </nav>
</aside>

<script>
  // Mobile toggle
  var toggle = document.getElementById('sidebar-toggle');
  var sidebar = document.getElementById('sidebar');
  var overlay = document.getElementById('sidebar-overlay');

  function openSidebar() {
    sidebar.classList.remove('-translate-x-full');
    overlay.classList.remove('hidden');
  }
  function closeSidebar() {
    sidebar.classList.add('-translate-x-full');
    overlay.classList.add('hidden');
  }

  if (toggle) toggle.addEventListener('click', openSidebar);
  if (overlay) overlay.addEventListener('click', closeSidebar);

  // Close sidebar on link click (mobile)
  sidebar.querySelectorAll('.nav-link').forEach(function(link) {
    link.addEventListener('click', function() {
      if (window.innerWidth < 1024) closeSidebar();
    });
  });

  // Active link via IntersectionObserver
  var sections = document.querySelectorAll('section[id]');
  var navLinks = document.querySelectorAll('.nav-link');

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        navLinks.forEach(function(link) {
          link.classList.remove('text-white', 'bg-slate-800');
          link.classList.add('text-slate-400');
        });
        var active = document.querySelector('.nav-link[data-section="' + entry.target.id + '"]');
        if (active) {
          active.classList.add('text-white', 'bg-slate-800');
          active.classList.remove('text-slate-400');
        }
      }
    });
  }, { threshold: 0.2, rootMargin: '-10% 0px -60% 0px' });

  sections.forEach(function(s) { observer.observe(s); });
</script>
